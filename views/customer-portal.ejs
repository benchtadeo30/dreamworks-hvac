        .doc-img-placeholder {
            width: 100%;
            height: 160px;
            background: linear-gradient(135deg, #E4ECFF, #D6E4FF);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 0.4rem;
            position: relative;
            overflow: hidden;
        }

        .doc-img-placeholder::before {
            content: '';
            position: absolute; inset: 0;
            background: repeating-linear-gradient(
                45deg,
