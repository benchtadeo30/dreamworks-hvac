<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Customer Portal — DreamWorks HVAC</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Barlow:wght@400;500;600;700;800&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
        :root {
            --primary: #0038FF;
            --primary-dark: #0028CC;
            --primary-light: #3D68FF;
            --secondary: #00D4FF;
            --dark: #0A0F1C;
            --dark-blue: #1A1F35;
            --gray: #64748B;
            --light-gray: #E2E8F0;
            --white: #FFFFFF;
            --success: #10B981;
            --warning: #F59E0B;
            --error: #EF4444;
            --bg: #F0F4FF;
        }

        body {
            font-family: 'Outfit', sans-serif;
            background: var(--bg);
            min-height: 100vh;
            color: var(--dark);
        }

        /* ============ TOP BAR ============ */
        .portal-topbar {
            background: linear-gradient(135deg, #0038FF 0%, #0028CC 55%, #1A1F35 100%);
            padding: 0 2.5rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            height: 68px;
            box-shadow: 0 4px 24px rgba(0,56,255,0.25);
            position: sticky;
            top: 0;
            z-index: 200;
        }

        .topbar-left {
            display: flex;
            align-items: center;
            gap: 2.5rem;
        }

        .brand {
            font-family: 'Barlow', sans-serif;
            font-size: 1.55rem;
            font-weight: 800;
            color: #fff;
            text-transform: uppercase;
            letter-spacing: -0.5px;
            text-decoration: none;
            white-space: nowrap;
        }

        .brand span { color: var(--secondary); }

        /* Top-bar nav links */
        .topbar-nav {
            display: flex;
            gap: 0.3rem;
        }

        .topbar-link {
            padding: 0.45rem 1.1rem;
            border-radius: 50px;
            font-size: 0.85rem;
            font-weight: 600;
            text-decoration: none;
            color: rgba(255,255,255,0.8);
            border: 1.5px solid transparent;
            transition: all 0.25s;
        }

        .topbar-link:hover {
            background: rgba(255,255,255,0.12);
            color: #fff;
        }

        .topbar-link.outbound {
            border-color: rgba(255,255,255,0.3);
        }

        .topbar-right {
            display: flex;
            align-items: center;
            gap: 1.2rem;
        }

        .greeting-text {
            color: rgba(255,255,255,0.85);
            font-size: 0.9rem;
            font-weight: 500;
        }

        .greeting-text strong { color: #fff; }

        .topbar-btn {
            padding: 0.48rem 1.2rem;
            border-radius: 50px;
            font-family: 'Outfit', sans-serif;
            font-size: 0.85rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.25s;
            text-decoration: none;
            border: 1.5px solid rgba(255,255,255,0.35);
            color: rgba(255,255,255,0.9);
            background: rgba(255,255,255,0.1);
        }

        .topbar-btn:hover { background: rgba(255,255,255,0.22); color: #fff; }

        /* ============ PORTAL NAV TABS ============ */
        .portal-nav {
            background: #fff;
            border-bottom: 2px solid var(--light-gray);
            padding: 0 2.5rem;
            display: flex;
            box-shadow: 0 2px 12px rgba(0,56,255,0.06);
            position: sticky;
            top: 68px;
            z-index: 100;
        }

        .portal-tab {
            display: flex;
            align-items: center;
            gap: 0.55rem;
            padding: 1rem 1.8rem;
            background: none;
            border: none;
            border-bottom: 3px solid transparent;
            margin-bottom: -2px;
            font-family: 'Outfit', sans-serif;
            font-size: 0.95rem;
            font-weight: 600;
            color: var(--gray);
            cursor: pointer;
            transition: all 0.25s;
            white-space: nowrap;
        }

        .portal-tab:hover { color: var(--primary); }
        .portal-tab.active { color: var(--primary); border-bottom-color: var(--primary); }

        .tab-badge {
            background: var(--success);
            color: #fff;
            font-size: 0.7rem;
            font-weight: 700;
            padding: 2px 6px;
            border-radius: 20px;
        }

        /* ============ PORTAL BODY ============ */
        .portal-body {
            max-width: 1320px;
            margin: 0 auto;
            padding: 2rem 2rem 4rem;
        }

        /* Panel visibility */
        .portal-panel { display: none; animation: fadeIn 0.35s ease; }
        .portal-panel.active { display: block; }

        /* ============ PANEL 1: DASHBOARD ============ */
        .dashboard-layout {
            display: grid;
            grid-template-columns: 1fr 300px;
            gap: 1.8rem;
            align-items: start;
        }

        .dashboard-left { display: flex; flex-direction: column; gap: 1.8rem; }

        /* Quick actions */
        .quick-bar {
            display: flex;
            gap: 0.8rem;
            flex-wrap: wrap;
            margin-bottom: 0.2rem;
        }

        .qbtn {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.65rem 1.4rem;
            border-radius: 10px;
            font-family: 'Outfit', sans-serif;
            font-size: 0.88rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.25s;
            text-decoration: none;
            border: none;
        }

        .qbtn-primary {
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            color: #fff;
            box-shadow: 0 4px 16px rgba(0,56,255,0.28);
        }

        .qbtn-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,56,255,0.38); }

        .qbtn-ghost {
            background: #fff;
            color: var(--primary);
            border: 1.5px solid #D6E0FF;
            box-shadow: 0 2px 8px rgba(0,56,255,0.07);
        }

        .qbtn-ghost:hover { background: var(--primary); color: #fff; border-color: var(--primary); transform: translateY(-2px); }

        /* Portal card */
        .portal-card {
            background: #fff;
            border-radius: 18px;
            padding: 1.8rem;
            box-shadow: 0 4px 22px rgba(0,56,255,0.07);
            border: 1.5px solid var(--light-gray);
        }

        .section-title {
            font-family: 'Barlow', sans-serif;
            font-size: 1.35rem;
            font-weight: 800;
            color: var(--dark);
            margin-bottom: 1.2rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        /* Services grid */
        .services-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1rem;
        }

        .service-tile {
            background: linear-gradient(135deg, #F6F9FF, #EDF1FF);
            border: 1.5px solid #D6E0FF;
            border-radius: 13px;
            padding: 1.3rem 0.9rem;
            text-align: center;
            cursor: pointer;
            transition: all 0.28s;
        }

        .service-tile:hover {
            border-color: var(--primary);
            box-shadow: 0 8px 28px rgba(0,56,255,0.14);
            transform: translateY(-4px);
            background: linear-gradient(135deg, #EDF1FF, #DDE6FF);
        }

        .tile-icon { font-size: 2rem; margin-bottom: 0.5rem; }
        .tile-name { font-weight: 700; font-size: 0.85rem; color: var(--dark); margin-bottom: 0.25rem; }
        .tile-desc { font-size: 0.75rem; color: var(--gray); line-height: 1.4; }

        .tile-cta {
            display: inline-block;
            margin-top: 0.65rem;
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            color: #fff;
            font-size: 0.72rem;
            font-weight: 700;
            padding: 3px 10px;
            border-radius: 20px;
        }

        /* Docs grid */
        .docs-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.1rem; }

        .doc-card {
            border-radius: 13px;
            overflow: hidden;
            border: 1.5px solid var(--light-gray);
            background: #fff;
            transition: all 0.28s;
        }

        .doc-card:hover { transform: translateY(-3px); box-shadow: 0 10px 28px rgba(0,56,255,0.12); border-color: var(--primary); }

        .doc-img {
            width: 100%;
            height: 145px;
            background: linear-gradient(135deg, #E4ECFF, #D6E4FF);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 0.4rem;
            border-bottom: 1.5px solid var(--light-gray);
            position: relative;
            overflow: hidden;
        }

        .doc-img::before {
            content: '';
            position: absolute;
            inset: 0;
            background: repeating-linear-gradient(
                45deg,
                transparent, transparent 10px,
                rgba(0,56,255,0.04) 10px, rgba(0,56,255,0.04) 20px
            );
        }

        .doc-img-icon { font-size: 2.2rem; position: relative; z-index: 1; }
        .doc-img-text { font-size: 0.72rem; font-weight: 600; letter-spacing: 0.8px; text-transform: uppercase; color: #82A4D8; position: relative; z-index: 1; }

        .doc-info { padding: 0.8rem 0.9rem; }
        .doc-title { font-weight: 700; font-size: 0.85rem; color: var(--dark); margin-bottom: 0.3rem; }
        .doc-meta { font-size: 0.75rem; color: var(--gray); display: flex; align-items: center; gap: 0.4rem; flex-wrap: wrap; }

        .status-pill {
            display: inline-block;
            padding: 2px 8px;
            border-radius: 10px;
            font-size: 0.7rem;
            font-weight: 700;
        }

        .status-pill.done { background: #DCFCE7; color: #16A34A; }
        .status-pill.ongoing { background: #FEF3C7; color: #D97706; }

        /* ============ TAGLINE SIDEBAR ============ */
        .dashboard-right { position: sticky; top: 148px; }

        .tagline-card {
            background: linear-gradient(160deg, #0038FF 0%, #0028CC 50%, #1A1F35 100%);
            border-radius: 18px;
            padding: 1.8rem 1.6rem;
            color: #fff;
            box-shadow: 0 12px 40px rgba(0,56,255,0.3);
            min-height: 380px;
            display: flex;
            flex-direction: column;
            position: relative;
            overflow: hidden;
        }

        .tagline-card::before {
            content: '';
            position: absolute;
            top: -30px; right: -30px;
            width: 150px; height: 150px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(0,212,255,0.22), transparent 70%);
            pointer-events: none;
        }

        .tagline-card::after {
            content: '';
            position: absolute;
            bottom: -20px; left: -20px;
            width: 110px; height: 110px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(61,104,255,0.28), transparent 70%);
            pointer-events: none;
        }

        .tagline-label {
            font-size: 0.72rem;
            font-weight: 700;
            letter-spacing: 2px;
            color: var(--secondary);
            text-transform: uppercase;
            margin-bottom: 1rem;
            position: relative; z-index: 1;
        }

        .tagline-box {
            flex: 1;
            background: rgba(255,255,255,0.07);
            border: 1.5px dashed rgba(255,255,255,0.22);
            border-radius: 12px;
            padding: 1.3rem;
            min-height: 170px;
            position: relative; z-index: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            color: rgba(255,255,255,0.3);
            font-size: 0.85rem;
            font-style: italic;
            text-align: center;
        }

        .tagline-footer { margin-top: 1.3rem; position: relative; z-index: 1; }

        .tagline-brand {
            font-family: 'Barlow', sans-serif;
            font-size: 1.2rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: -0.5px;
        }

        .tagline-brand span { color: var(--secondary); }
        .tagline-footer p { font-size: 0.76rem; color: rgba(255,255,255,0.55); margin-top: 0.25rem; }

        /* ============ PANEL 2: PAYMENT ============ */
        .payment-layout { max-width: 820px; margin: 0 auto; }

        .payment-hero {
            background: linear-gradient(135deg, #0038FF, #0028CC, #1A1F35);
            border-radius: 18px;
            padding: 2.5rem;
            color: #fff;
            text-align: center;
            margin-bottom: 1.8rem;
            position: relative;
            overflow: hidden;
        }

        .payment-hero::before {
            content: '';
            position: absolute; inset: 0;
            background: radial-gradient(circle at 30% 50%, rgba(0,212,255,0.18), transparent 60%),
                        radial-gradient(circle at 80% 20%, rgba(61,104,255,0.2), transparent 50%);
            pointer-events: none;
        }

        .payment-hero h2 {
            font-family: 'Barlow', sans-serif;
            font-size: 2rem;
            font-weight: 800;
            margin-bottom: 0.5rem;
            position: relative; z-index: 1;
        }

        .payment-hero p { color: rgba(255,255,255,0.8); position: relative; z-index: 1; font-size: 0.95rem; }

        .payment-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.3rem; margin-bottom: 1.8rem; }

        .payment-card {
            background: #fff;
            border-radius: 16px;
            padding: 1.8rem;
            border: 2px solid var(--light-gray);
            cursor: pointer;
            transition: all 0.28s;
            text-align: center;
        }

        .payment-card:hover { border-color: var(--primary); box-shadow: 0 10px 28px rgba(0,56,255,0.12); transform: translateY(-4px); }

        .payment-card .p-icon { font-size: 2.8rem; margin-bottom: 0.9rem; }
        .payment-card h3 { font-family: 'Barlow', sans-serif; font-size: 1.2rem; font-weight: 700; color: var(--dark); margin-bottom: 0.5rem; }
        .payment-card p { color: var(--gray); font-size: 0.88rem; line-height: 1.5; }

        .p-cta {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            margin-top: 1.2rem;
            padding: 0.62rem 1.4rem;
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            color: #fff;
            border-radius: 50px;
            font-family: 'Outfit', sans-serif;
            font-weight: 700;
            font-size: 0.85rem;
            border: none;
            cursor: pointer;
            transition: all 0.28s;
            box-shadow: 0 4px 14px rgba(0,56,255,0.28);
        }

        .p-cta:hover { transform: translateY(-2px); box-shadow: 0 8px 22px rgba(0,56,255,0.4); }

        .process-card {
            background: #fff;
            border-radius: 16px;
            padding: 1.8rem;
            border: 1.5px solid var(--light-gray);
            box-shadow: 0 4px 18px rgba(0,56,255,0.05);
        }

        .process-card h3 {
            font-family: 'Barlow', sans-serif;
            font-size: 1.1rem;
            font-weight: 700;
            color: var(--dark);
            margin-bottom: 1.2rem;
            display: flex; align-items: center; gap: 0.5rem;
        }

        .process-steps { display: flex; flex-direction: column; gap: 0.9rem; }

        .process-step {
            display: flex;
            align-items: flex-start;
            gap: 1rem;
            padding: 0.8rem;
            border-radius: 10px;
            background: #F6F9FF;
            border: 1px solid #E4ECFF;
        }

        .step-num {
            width: 30px; height: 30px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            color: #fff;
            font-weight: 800;
            font-size: 0.8rem;
            display: flex; align-items: center; justify-content: center;
            flex-shrink: 0;
        }

        .step-content h4 { font-weight: 700; font-size: 0.88rem; color: var(--dark); margin-bottom: 0.18rem; }
        .step-content p { font-size: 0.8rem; color: var(--gray); line-height: 1.5; }

        /* ============ PANEL 3: PROGRESS ============ */
        .progress-panel { max-width: 700px; margin: 0 auto; text-align: center; padding: 3.5rem 2rem; }
        .progress-panel .big-icon { font-size: 4.5rem; margin-bottom: 1.3rem; }
        .progress-panel h2 { font-family: 'Barlow', sans-serif; font-size: 1.8rem; font-weight: 800; color: var(--dark); margin-bottom: 0.7rem; }
        .progress-panel > p { color: var(--gray); font-size: 0.95rem; max-width: 440px; margin: 0 auto 1.8rem; line-height: 1.7; }

        .progress-placeholder {
            background: #fff;
            border-radius: 16px;
            padding: 2.5rem;
            border: 2px dashed #CBD5E1;
            color: #94A3B8;
            font-size: 0.93rem;
            font-style: italic;
            margin-top: 1.5rem;
            line-height: 1.7;
        }

        /* Animations */
        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

        /* Responsive */
        @media (max-width: 960px) {
            .dashboard-layout { grid-template-columns: 1fr; }
            .dashboard-right { position: static; }
            .services-grid { grid-template-columns: repeat(2, 1fr); }
            .payment-grid { grid-template-columns: 1fr; }
        }

        @media (max-width: 680px) {
            .portal-topbar { padding: 0 1.2rem; height: auto; padding-top: 0.8rem; padding-bottom: 0.8rem; flex-wrap: wrap; gap: 0.5rem; }
            .topbar-left { flex-wrap: wrap; gap: 0.6rem; }
            .topbar-nav { gap: 0.2rem; }
            .topbar-link { padding: 0.4rem 0.7rem; font-size: 0.78rem; }
            .portal-nav { padding: 0 1rem; top: auto; overflow-x: auto; }
            .portal-tab { padding: 0.85rem 1rem; font-size: 0.85rem; }
            .portal-body { padding: 1.5rem 1rem 3rem; }
            .services-grid { grid-template-columns: 1fr 1fr; }
            .docs-grid { grid-template-columns: 1fr; }
            .greeting-text { display: none; }
        }

        /* ============ PANEL 3: PROJECT PROGRESS (REDESIGNED) ============ */

        /* Project selector bar */
        .project-selector {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            margin-bottom: 1.8rem;
            flex-wrap: wrap;
        }

        .project-selector-label {
            font-size: 0.82rem;
            font-weight: 700;
            color: var(--gray);
            text-transform: uppercase;
            letter-spacing: 0.8px;
            white-space: nowrap;
        }

        .proj-btn {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.6rem 1.25rem;
            border-radius: 50px;
            border: 2px solid var(--light-gray);
            background: #fff;
            font-family: 'Outfit', sans-serif;
            font-size: 0.88rem;
            font-weight: 600;
            color: var(--gray);
            cursor: pointer;
            transition: all 0.25s;
            box-shadow: 0 2px 8px rgba(0,56,255,0.06);
        }

        .proj-btn:hover {
            border-color: var(--primary);
            color: var(--primary);
            transform: translateY(-2px);
        }

        .proj-btn.active {
            background: linear-gradient(135deg, var(--primary), #1a56ff);
            border-color: transparent;
            color: #fff;
            box-shadow: 0 4px 16px rgba(0,56,255,0.3);
        }

        .proj-btn .proj-status-dot {
            width: 8px; height: 8px;
            border-radius: 50%;
            background: var(--success);
            flex-shrink: 0;
        }

        .proj-btn.active .proj-status-dot {
            background: rgba(255,255,255,0.8);
        }

        /* Project detail card */
        .project-detail-card {
            background: #fff;
            border-radius: 20px;
            border: 1.5px solid var(--light-gray);
            box-shadow: 0 4px 24px rgba(0,56,255,0.07);
            overflow: hidden;
            display: none;
            animation: fadeInUp 0.35s ease;
        }

        .project-detail-card.active { display: block; }

        /* Project card header */
        .project-card-header {
            background: linear-gradient(135deg, #0038FF, #0028CC, #1A1F35);
            padding: 1.6rem 2rem;
            color: #fff;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 1rem;
            position: relative;
            overflow: hidden;
        }

        .project-card-header::before {
            content: '';
            position: absolute;
            top: -20px; right: -20px;
            width: 120px; height: 120px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(0,212,255,0.2), transparent 70%);
            pointer-events: none;
        }

        .project-card-header-left { position: relative; z-index: 1; }
        .project-card-header-left h3 {
            font-family: 'Barlow', sans-serif;
            font-size: 1.4rem;
            font-weight: 800;
            margin-bottom: 0.3rem;
        }

        .project-card-header-left p {
            font-size: 0.85rem;
            color: rgba(255,255,255,0.75);
        }

        .project-overall-badge {
            background: rgba(255,255,255,0.15);
            border: 1.5px solid rgba(255,255,255,0.3);
            border-radius: 50px;
            padding: 0.4rem 1rem;
            font-size: 0.82rem;
            font-weight: 700;
            color: #fff;
            position: relative;
            z-index: 1;
            white-space: nowrap;
        }

        .project-card-body { padding: 2rem; }

        /* Timeline track */
        .timeline-wrapper {
            margin-bottom: 2rem;
        }

        .timeline-track-label {
            font-size: 0.8rem;
            font-weight: 700;
            color: var(--gray);
            text-transform: uppercase;
            letter-spacing: 0.8px;
            margin-bottom: 1rem;
        }

        .timeline-track {
            position: relative;
            padding: 0 0 0 0;
        }

        /* The rail line */
        .timeline-rail {
            position: relative;
            height: 6px;
            background: var(--light-gray);
            border-radius: 99px;
            margin: 0 3rem;
            margin-bottom: 0;
        }

        .timeline-rail-fill {
            position: absolute;
            top: 0; left: 0;
            height: 100%;
            border-radius: 99px;
            background: linear-gradient(90deg, var(--primary), var(--secondary));
            transition: width 0.5s ease;
        }

        /* Milestone nodes row */
        .timeline-milestones {
            display: flex;
            justify-content: space-between;
            margin-top: -22px;
            padding: 0 0;
            position: relative;
        }

        .milestone-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0.5rem;
            cursor: pointer;
            flex: 1;
        }

        .milestone-node {
            width: 44px; height: 44px;
            border-radius: 50%;
            background: #fff;
            border: 3px solid var(--light-gray);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.82rem;
            font-weight: 800;
            color: var(--gray);
