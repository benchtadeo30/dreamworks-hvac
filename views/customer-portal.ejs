            align-items: center;
            gap: 0.7rem;
            font-size: 0.82rem;
            color: var(--gray);
        }

        /* Image + week grid */
        .doc-images-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
            gap: 1.1rem;
        }

        .doc-img-card {
            border-radius: 14px;
            overflow: hidden;
            border: 1.5px solid var(--light-gray);
            background: #fff;
