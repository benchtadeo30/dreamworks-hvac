    <script>
        // Restore greeting from session
        const topbarBtn = document.querySelector(".topbar-btn")
        topbarBtn.addEventListener("click", async () => {
           const isSignOut = confirm("Are you sure you want to sign out? This action cannot be reverted.")
           if(isSignOut){
             try {
                const response = await fetch("customer/signout", {method: 'GET'})
                if(!response.ok){
                    throw Error;
                }
                const res = await response.url;
                window.location.href = res
            } catch (error) {
                alert("Cannot signout. There's a problem on a server!")
            }
           }else{
            alert("Signout Cancelled.")
           }
        })
        const name = sessionStorage.getItem('customerName');
        if (name) document.getElementById('portalGreeting').textContent = name;

        function switchTab(panelId, btnEl) {
            document.querySelectorAll('.portal-panel').forEach(p => p.classList.remove('active'));
            document.querySelectorAll('.portal-tab').forEach(b => b.classList.remove('active'));
            document.getElementById('panel-' + panelId).classList.add('active');
            if (btnEl) btnEl.classList.add('active');
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        function selectProject(idx, btnEl) {
            document.querySelectorAll('.proj-btn').forEach(b => b.classList.remove('active'));
            document.querySelectorAll('.project-detail-card').forEach(c => c.classList.remove('active'));
            btnEl.classList.add('active');
            document.getElementById('project-' + idx).classList.add('active');
        }

        function showMilestone(projectId, msNum, nodeEl) {
            // Deactivate all milestone panels for this project
            const card = document.getElementById('project-' + projectId.replace('p',''));
            card.querySelectorAll('.milestone-doc-panel').forEach(p => p.classList.remove('active'));
            // Deactivate all milestone nodes for this project
            card.querySelectorAll('.milestone-item').forEach(m => m.classList.remove('active-ms'));
            // Activate selected
            document.getElementById(projectId + '-ms' + msNum).classList.add('active');
            nodeEl.classList.add('active-ms');
            // Scroll to doc panel smoothly
            setTimeout(() => {
                document.getElementById(projectId + '-ms' + msNum).scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            }, 50);
        }
    </script>
