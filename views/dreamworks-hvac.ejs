            color: var(--primary);
        }

        .nav-login-icon {
            font-size: 1.15rem;
            width: 28px;
            text-align: center;
            flex-shrink: 0;
        }

        .nav-login-text {
            display: flex;
            flex-direction: column;
            gap: 1px;
            flex: 1;
        }

        .nav-login-title {
            font-weight: 600;
            font-size: 0.88rem;
            color: var(--dark);
        }

        .nav-login-option:hover .nav-login-title {
            color: var(--primary);
        }

        .nav-login-sub {
            font-size: 0.75rem;
            color: var(--gray);
            font-weight: 400;
        }

        .nav-login-arrow {
            color: var(--gray);
            flex-shrink: 0;
            transition: transform 0.18s, color 0.18s;
        }

        .nav-login-option:hover .nav-login-arrow {
            transform: translateX(3px);
            color: var(--primary);
        }

        .nav-login-divider {
            height: 1px;
            background: #EEF0F5;
            margin: 0 1rem;
        }

        /* ── Employee Modal ──────────────────────────────── */
        .emp-modal-overlay {
            position: fixed;
            inset: 0;
            background: rgba(10, 15, 28, 0.55);
            backdrop-filter: blur(6px);
            z-index: 99999;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 1rem;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.28s ease;
        }

        .emp-modal-overlay.active {
            opacity: 1;
            pointer-events: all;
        }

        .emp-modal {
            background: #fff;
            border-radius: 24px;
            padding: 2.5rem 2rem 2rem;
            max-width: 400px;
            width: 100%;
            position: relative;
            text-align: center;
            box-shadow: 0 24px 60px rgba(0, 56, 255, 0.18), 0 4px 20px rgba(0,0,0,0.1);
            transform: translateY(20px) scale(0.97);
            transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.28s ease;
            opacity: 0;
        }

        .emp-modal-overlay.active .emp-modal {
            transform: translateY(0) scale(1);
            opacity: 1;
        }

        .emp-modal-close {
            position: absolute;
            top: 1rem;
            right: 1rem;
            background: #F1F5F9;
            border: none;
            border-radius: 50%;
            width: 34px;
            height: 34px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            color: var(--gray);
            transition: background 0.2s, color 0.2s;
        }

        .emp-modal-close:hover {
            background: #E2E8F0;
            color: var(--dark);
        }

        .emp-modal-icon {
            font-size: 2.6rem;
            margin-bottom: 0.75rem;
            line-height: 1;
        }

        .emp-modal-title {
            font-family: 'Barlow', sans-serif;
            font-size: 1.6rem;
            font-weight: 800;
            color: var(--dark);
            margin-bottom: 0.35rem;
            letter-spacing: -0.5px;
        }

        .emp-modal-sub {
            font-size: 0.9rem;
            color: var(--gray);
            margin-bottom: 1.75rem;
        }

        .emp-modal-options {
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
            margin-bottom: 1.5rem;
        }

        .emp-modal-card {
            display: flex;
            align-items: center;
            gap: 1rem;
            padding: 1rem 1.25rem;
            border-radius: 14px;
            text-decoration: none;
            transition: all 0.22s ease;
            border: 2px solid transparent;
            text-align: left;
        }

        .emp-admin {
            background: linear-gradient(135deg, #EEF2FF 0%, #E0E7FF 100%);
            border-color: #C7D2FE;
        }

        .emp-admin:hover {
            background: linear-gradient(135deg, #E0E7FF 0%, #C7D2FE 100%);
            border-color: var(--primary);
            transform: translateX(4px);
            box-shadow: 0 6px 20px rgba(0, 56, 255, 0.15);
        }

        .emp-tech {
            background: linear-gradient(135deg, #F0FDF4 0%, #DCFCE7 100%);
            border-color: #BBF7D0;
        }

        .emp-tech:hover {
            background: linear-gradient(135deg, #DCFCE7 0%, #BBF7D0 100%);
            border-color: #22C55E;
            transform: translateX(4px);
            box-shadow: 0 6px 20px rgba(34, 197, 94, 0.15);
        }

        .emp-card-icon {
            font-size: 1.8rem;
            width: 44px;
            height: 44px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: rgba(255,255,255,0.7);
            border-radius: 12px;
            flex-shrink: 0;
        }

        .emp-card-body {
            display: flex;
            flex-direction: column;
            gap: 2px;
            flex: 1;
        }

        .emp-card-title {
            font-weight: 700;
            font-size: 0.95rem;
            color: var(--dark);
        }

        .emp-card-desc {
            font-size: 0.78rem;
            color: var(--gray);
        }

        .emp-card-arrow {
            color: var(--gray);
            flex-shrink: 0;
            transition: transform 0.2s, color 0.2s;
        }

        .emp-modal-card:hover .emp-card-arrow {
            transform: translateX(3px);
        }

        .emp-admin:hover .emp-card-arrow { color: var(--primary); }
        .emp-tech:hover .emp-card-arrow  { color: #16A34A; }

        .emp-modal-footer {
            font-size: 0.78rem;
            color: #94A3B8;
        }

        .emp-modal-help {
            color: var(--primary);
            text-decoration: none;
            font-weight: 500;
        }

        .emp-modal-help:hover {
            text-decoration: underline;
        }
    </style>

    <script>
        (function () {
            /* ── Nav Login Dropdown ── */
            const navLoginToggle = document.getElementById("navLoginToggle")
            var navToggle   = document.getElementById('navLoginToggle');
            var navDropdown = document.getElementById('navLoginDropdown');
            var navWrapper  = document.getElementById('navLoginWrapper');

            if(navLoginToggle.textContent.trim() === 'Customer Portal'){
            const handleLoginToggle = () => window.location.href = "/customer";

            navLoginToggle.removeEventListener("click", handleLoginToggle)
            navLoginToggle.addEventListener("click", handleLoginToggle)
            }

            if(!navToggle) return;
            if(!navDropdown) return;
            if(!navWrapper) return;

            navToggle.addEventListener('click', function (e) {
                e.stopPropagation();
                var isOpen = navDropdown.classList.toggle('open');
                navToggle.classList.toggle('open', isOpen);
            });

            document.addEventListener('click', function (e) {
                if (!navWrapper.contains(e.target)) {
                    navDropdown.classList.remove('open');
                    navToggle.classList.remove('open');
                }
            });

            /* ── Employee Modal ── */
            var overlay     = document.getElementById('empModalOverlay');
            var empTrigger  = document.getElementById('navEmployeeTrigger');
            var closeBtn    = document.getElementById('empModalClose');
            var modal       = document.getElementById('empModal');

            function openModal() {
                overlay.classList.add('active');
                document.body.style.overflow = 'hidden';
                navDropdown.classList.remove('open');
                navToggle.classList.remove('open');
            }

            function closeModal() {
                overlay.classList.remove('active');
                document.body.style.overflow = '';
            }

            empTrigger.addEventListener('click', function (e) {
                e.stopPropagation();
                openModal();
            });

            closeBtn.addEventListener('click', closeModal);

            overlay.addEventListener('click', function (e) {
                if (!modal.contains(e.target)) closeModal();
            });

            document.addEventListener('keydown', function (e) {
                if (e.key === 'Escape') closeModal();
            });
        })();
    </script>

</body>
</html>
