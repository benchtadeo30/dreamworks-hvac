<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Employee Portal — DreamWorks HVAC</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Barlow:wght@400;500;600;700;800&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
    :root {
      --primary: #0038FF;
      --primary-dark: #0028CC;
      --primary-light: #3D68FF;
      --secondary: #00D4FF;
      --dark: #0A0F1C;
      --dark-blue: #1A1F35;
      --gray: #64748B;
      --light-gray: #E2E8F0;
      --white: #FFFFFF;
      --success: #10B981;
      --warning: #F59E0B;
      --error: #EF4444;
      --bg: #F0F4FF;
      --card: #FFFFFF;
      --sidebar-w: 260px;
    }

    body {
      font-family: 'Outfit', sans-serif;
      background: var(--bg);
      min-height: 100vh;
      color: var(--dark);
    }

    /* ─── TOP BAR ─── */
    .topbar {
      background: linear-gradient(135deg, #0038FF 0%, #0028CC 55%, #1A1F35 100%);
      height: 64px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 1.5rem;
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 300;
      box-shadow: 0 4px 24px rgba(0,56,255,0.25);
    }
    .topbar-left { display:flex; align-items:center; gap:1rem; }
    .menu-btn {
      background: none; border: none; cursor: pointer;
      color:#fff; padding:6px; border-radius:8px;
      display:flex; align-items:center; justify-content:center;
      transition: background 0.2s;
    }
    .menu-btn:hover { background: rgba(255,255,255,0.15); }
    .brand {
      font-family: 'Barlow', sans-serif;
      font-weight: 800;
      font-size: 1.4rem;
      color: #fff;
      text-transform: uppercase;
      letter-spacing: -0.5px;
    }
    .brand span { color: var(--secondary); }
    .brand sub {
      font-size: 0.6rem;
      font-weight: 500;
      letter-spacing: 1px;
      opacity: 0.7;
      display: block;
      line-height: 1;
      text-transform: uppercase;
    }
    .topbar-right { display:flex; align-items:center; gap:1rem; }
    .emp-badge {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      background: rgba(255,255,255,0.12);
      border-radius: 40px;
      padding: 6px 14px 6px 6px;
    }
    .avatar {
      width: 34px; height: 34px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--secondary), var(--primary-light));
      display: flex; align-items:center; justify-content:center;
      font-weight: 700; font-size: 0.85rem; color: #fff;
      flex-shrink: 0;
    }
    .emp-info { line-height: 1.2; }
    .emp-name { font-size: 0.85rem; font-weight: 600; color:#fff; }
    .emp-role { font-size: 0.7rem; color: rgba(255,255,255,0.65); }
    .notif-btn {
      position: relative;
      background: rgba(255,255,255,0.12);
      border: none; cursor: pointer;
      color:#fff; width:38px; height:38px;
      border-radius: 50%; display:flex; align-items:center; justify-content:center;
      transition: background 0.2s;
    }
    .notif-btn:hover { background: rgba(255,255,255,0.25); }
    .notif-dot {
      position: absolute; top:6px; right:6px;
      width:9px; height:9px;
      background: var(--warning);
      border-radius: 50%;
      border: 2px solid var(--primary-dark);
    }

    /* ─── LAYOUT ─── */
    .layout {
      display: flex;
      padding-top: 64px;
      min-height: 100vh;
    }

    /* ─── SIDEBAR ─── */
    .sidebar {
      width: var(--sidebar-w);
      background: var(--dark);
      position: fixed;
      top: 64px; left: 0; bottom: 0;
      overflow-y: auto;
      overflow-x: hidden;
      z-index: 200;
      transition: transform 0.3s ease, width 0.3s ease;
      display: flex;
      flex-direction: column;
    }
    .sidebar.collapsed { transform: translateX(-100%); }
    .sidebar-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.5);
      z-index: 199;
    }
    .sidebar-overlay.visible { display: block; }

    .sidebar-section {
      padding: 1.2rem 1rem 0.5rem;
      font-size: 0.65rem;
      font-weight: 700;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: rgba(255,255,255,0.3);
    }
    .nav-item {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 0.75rem 1.2rem;
      color: rgba(255,255,255,0.65);
      cursor: pointer;
      border-radius: 10px;
      margin: 2px 8px;
      transition: all 0.2s;
      font-size: 0.9rem;
      font-weight: 500;
      border: none; background: none; width: calc(100% - 16px);
      text-align: left;
    }
    .nav-item svg { flex-shrink: 0; }
    .nav-item:hover { background: rgba(255,255,255,0.07); color:#fff; }
    .nav-item.active {
      background: linear-gradient(135deg, rgba(0,56,255,0.5), rgba(0,212,255,0.2));
      color: #fff;
      box-shadow: 0 2px 12px rgba(0,56,255,0.3);
    }
    .nav-item .badge {
      margin-left: auto;
      background: var(--primary);
      color: #fff;
      font-size: 0.65rem;
      font-weight: 700;
      padding: 2px 7px;
      border-radius: 20px;
      min-width: 22px;
      text-align: center;
    }
    .nav-item .badge.green { background: var(--success); }
    .nav-item .badge.orange { background: var(--warning); }
    .sidebar-footer {
      margin-top: auto;
      padding: 1rem;
      border-top: 1px solid rgba(255,255,255,0.08);
    }
    .logout-btn {
      display: flex; align-items: center; gap: 0.75rem;
      padding: 0.75rem 1rem;
      color: rgba(255,255,255,0.5);
      cursor: pointer;
      border-radius: 10px;
      transition: all 0.2s;
      font-size: 0.85rem;
      font-weight: 500;
      border: none; background: none; width: 100%;
    }
    .logout-btn:hover { background: rgba(239,68,68,0.15); color: #EF4444; }

    /* ─── MAIN ─── */
    .main {
      flex: 1;
      margin-left: var(--sidebar-w);
      padding: 1.5rem;
      transition: margin-left 0.3s;
      min-width: 0;
    }
    .main.expanded { margin-left: 0; }

    .page { display: none; }
    .page.active { display: block; }

    /* ─── PAGE HEADER ─── */
    .page-header {
      margin-bottom: 1.5rem;
    }
    .page-title {
      font-family: 'Barlow', sans-serif;
      font-size: 1.6rem;
      font-weight: 800;
      color: var(--dark);
      text-transform: uppercase;
    }
    .page-sub { font-size: 0.85rem; color: var(--gray); margin-top: 2px; }

    /* ─── CARDS ─── */
    .card {
      background: var(--card);
      border-radius: 16px;
      padding: 1.4rem;
      box-shadow: 0 2px 12px rgba(0,56,255,0.06);
      border: 1px solid rgba(0,56,255,0.07);
    }
    .card-title {
      font-family: 'Barlow', sans-serif;
      font-weight: 700;
      font-size: 1rem;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin-bottom: 1rem;
      color: var(--dark);
      display: flex; align-items: center; gap: 0.5rem;
    }
    .card-title .dot {
      width: 8px; height: 8px; border-radius: 50%;
      background: var(--primary);
    }

    /* ─── GRID LAYOUTS ─── */
    .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .grid-3 { display: grid; grid-template-columns: repeat(3,1fr); gap: 1rem; }
    .grid-4 { display: grid; grid-template-columns: repeat(4,1fr); gap: 1rem; }
    .gap { gap: 1rem; }
    .flex-col { display: flex; flex-direction: column; gap: 1rem; }

    /* ─── STAT CARDS ─── */
    .stat-card {
      background: var(--card);
      border-radius: 16px;
      padding: 1.2rem;
      box-shadow: 0 2px 12px rgba(0,56,255,0.06);
      border: 1px solid rgba(0,56,255,0.07);
      display: flex; align-items: center; gap: 1rem;
    }
    .stat-icon {
      width: 48px; height: 48px;
      border-radius: 12px;
      display: flex; align-items:center; justify-content:center;
      flex-shrink: 0;
    }
    .stat-icon.blue { background: rgba(0,56,255,0.1); color: var(--primary); }
    .stat-icon.green { background: rgba(16,185,129,0.1); color: var(--success); }
    .stat-icon.orange { background: rgba(245,158,11,0.1); color: var(--warning); }
    .stat-icon.cyan { background: rgba(0,212,255,0.12); color: #0099BB; }
    .stat-val { font-family:'Barlow',sans-serif; font-size:1.6rem; font-weight:800; line-height:1; }
    .stat-label { font-size:0.75rem; color:var(--gray); font-weight:500; margin-top:2px; }

    /* ─── STATUS PILLS ─── */
    .pill {
      display: inline-flex; align-items: center; gap: 4px;
      padding: 3px 10px; border-radius: 20px;
      font-size: 0.72rem; font-weight: 600;
    }
    .pill::before { content:''; width:6px; height:6px; border-radius:50%; }
    .pill.green { background:rgba(16,185,129,0.12); color:#047857; }
    .pill.green::before { background:#10B981; }
    .pill.orange { background:rgba(245,158,11,0.12); color:#B45309; }
    .pill.orange::before { background:#F59E0B; }
    .pill.red { background:rgba(239,68,68,0.12); color:#B91C1C; }
    .pill.red::before { background:#EF4444; }
    .pill.blue { background:rgba(0,56,255,0.1); color:var(--primary-dark); }
    .pill.blue::before { background:var(--primary); }
    .pill.gray { background:rgba(100,116,139,0.1); color:var(--gray); }
    .pill.gray::before { background:var(--gray); }

    /* ─── BUTTONS ─── */
    .btn {
      display: inline-flex; align-items: center; gap: 0.5rem;
      padding: 0.6rem 1.2rem;
      border-radius: 10px;
      font-family: 'Outfit', sans-serif;
      font-weight: 600; font-size: 0.875rem;
      cursor: pointer; border: none; transition: all 0.2s;
      text-decoration: none;
    }
    .btn-primary {
      background: var(--primary);
      color: #fff;
      box-shadow: 0 4px 16px rgba(0,56,255,0.3);
    }
    .btn-primary:hover { background: var(--primary-dark); transform: translateY(-1px); }
    .btn-success {
      background: var(--success);
      color: #fff;
      box-shadow: 0 4px 16px rgba(16,185,129,0.3);
    }
    .btn-success:hover { background: #059669; transform: translateY(-1px); }
    .btn-danger {
      background: var(--error);
      color: #fff;
      box-shadow: 0 4px 16px rgba(239,68,68,0.3);
    }
    .btn-danger:hover { background: #DC2626; }
    .btn-outline {
      background: transparent;
      color: var(--primary);
      border: 1.5px solid var(--primary);
    }
    .btn-outline:hover { background: rgba(0,56,255,0.06); }
    .btn-gray {
      background: var(--light-gray);
      color: var(--gray);
    }
    .btn-gray:hover { background: #CBD5E1; }
    .btn-sm { padding: 0.45rem 0.9rem; font-size: 0.8rem; border-radius: 8px; }
    .btn-lg { padding: 0.85rem 1.8rem; font-size: 1rem; }
    .btn-block { width: 100%; justify-content: center; }

    /* ─── FORMS ─── */
    .form-group { margin-bottom: 1rem; }
    .form-label {
      display: block;
      font-size: 0.8rem;
      font-weight: 600;
      color: var(--gray);
      margin-bottom: 0.4rem;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    .form-control {
      width: 100%;
      padding: 0.65rem 0.9rem;
      border: 1.5px solid var(--light-gray);
      border-radius: 10px;
      font-family: 'Outfit', sans-serif;
      font-size: 0.9rem;
      color: var(--dark);
      background: #fff;
      transition: border-color 0.2s;
      outline: none;
    }
    .form-control:focus { border-color: var(--primary); box-shadow: 0 0 0 3px rgba(0,56,255,0.1); }
    textarea.form-control { resize: vertical; min-height: 90px; }

    /* ─── TIME CLOCK ─── */
    .clock-display {
      text-align: center;
      padding: 2rem 1rem;
    }
    .clock-time {
      font-family: 'Barlow', sans-serif;
      font-size: 3.5rem;
      font-weight: 800;
      color: var(--dark);
      line-height: 1;
      letter-spacing: -1px;
    }
    .clock-date {
      font-size: 0.9rem;
      color: var(--gray);
      margin-top: 0.5rem;
    }
    .clock-status {
      margin-top: 1rem;
      display: flex; align-items:center; justify-content:center; gap: 0.5rem;
      font-size: 0.9rem; font-weight: 600;
    }
    .status-indicator {
      width: 10px; height: 10px; border-radius: 50%;
      animation: pulse 2s infinite;
    }
    .status-indicator.clocked-in { background: var(--success); }
    .status-indicator.clocked-out { background: var(--gray); animation: none; }
    @keyframes pulse {
      0%,100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.6; transform: scale(1.2); }
    }
    .clock-actions { display:flex; gap:1rem; justify-content:center; margin-top: 1.5rem; flex-wrap: wrap; }
    .elapsed-time {
      background: linear-gradient(135deg, rgba(0,56,255,0.06), rgba(0,212,255,0.06));
      border: 1px solid rgba(0,56,255,0.1);
      border-radius: 12px;
      padding: 0.75rem 1.5rem;
      text-align: center;
      margin-top: 1rem;
    }
    .elapsed-val { font-family:'Barlow',sans-serif; font-size:1.4rem; font-weight:700; color: var(--primary); }
    .elapsed-label { font-size:0.72rem; color:var(--gray); font-weight:600; text-transform:uppercase; }

    /* ─── PHOTO UPLOAD ─── */
    .upload-zone {
      border: 2px dashed var(--light-gray);
      border-radius: 12px;
      padding: 1.5rem;
      text-align: center;
      cursor: pointer;
      transition: all 0.2s;
      background: #fafcff;
    }
    .upload-zone:hover { border-color: var(--primary); background: rgba(0,56,255,0.03); }
    .upload-zone.has-file { border-color: var(--success); background: rgba(16,185,129,0.03); }
    .upload-icon { font-size: 2rem; margin-bottom: 0.5rem; }
    .upload-text { font-size: 0.85rem; color: var(--gray); }
    .upload-text strong { color: var(--primary); }
    .upload-preview {
      display: grid; grid-template-columns: repeat(auto-fill, minmax(80px, 1fr)); gap: 0.5rem;
      margin-top: 0.75rem;
    }
    .preview-thumb {
      position: relative;
      aspect-ratio: 1;
      border-radius: 8px;
      overflow: hidden;
      background: var(--light-gray);
    }
    .preview-thumb img { width:100%; height:100%; object-fit:cover; }
    .preview-thumb .remove {
      position: absolute; top:3px; right:3px;
      background: rgba(0,0,0,0.6); color:#fff;
      border: none; border-radius: 50%; width:18px; height:18px;
      font-size: 10px; cursor: pointer;
      display: flex; align-items:center; justify-content:center;
    }

    /* ─── TASK CARDS ─── */
    .task-item {
      display: flex; align-items: flex-start; gap: 1rem;
      padding: 1rem;
      border: 1px solid var(--light-gray);
      border-radius: 12px;
      margin-bottom: 0.75rem;
      transition: all 0.2s;
      background: #fff;
    }
    .task-item:hover { border-color: rgba(0,56,255,0.2); box-shadow: 0 2px 12px rgba(0,56,255,0.06); }
    .task-priority {
      width: 4px; height: 100%;
      min-height: 50px;
      border-radius: 4px;
      flex-shrink: 0;
      align-self: stretch;
    }
    .task-priority.high { background: var(--error); }
    .task-priority.medium { background: var(--warning); }
    .task-priority.low { background: var(--success); }
    .task-body { flex: 1; min-width: 0; }
    .task-title { font-weight: 600; font-size: 0.95rem; margin-bottom: 0.25rem; }
    .task-meta { font-size: 0.78rem; color: var(--gray); display:flex; gap:1rem; flex-wrap:wrap; }
    .task-actions { display:flex; gap:0.5rem; flex-shrink:0; }
    .task-check {
      width: 22px; height: 22px;
      border-radius: 6px;
      border: 2px solid var(--light-gray);
      flex-shrink: 0;
      cursor: pointer;
      display:flex; align-items:center; justify-content:center;
      transition: all 0.2s;
      margin-top: 2px;
    }
    .task-check.done { background: var(--success); border-color: var(--success); color:#fff; }

    /* ─── ACTIVITY LOG ─── */
    .log-item {
      display: flex; gap: 1rem; padding: 0.75rem 0;
      border-bottom: 1px solid var(--light-gray);
    }
    .log-item:last-child { border-bottom: none; }
    .log-time { font-size: 0.75rem; color: var(--gray); flex-shrink:0; width: 72px; padding-top: 2px; }
    .log-dot {
      width: 10px; height: 10px; border-radius: 50%;
      flex-shrink: 0; margin-top: 5px;
    }
    .log-text { font-size: 0.85rem; flex: 1; }
    .log-text strong { font-weight: 600; }

    /* ─── CHAT ─── */
    .chat-container {
      display: flex; flex-direction: column; height: 420px;
    }
    .chat-messages {
      flex: 1; overflow-y: auto; padding: 1rem;
      display: flex; flex-direction: column; gap: 0.75rem;
    }
    .chat-bubble {
      max-width: 80%;
      padding: 0.65rem 0.9rem;
      border-radius: 14px;
      font-size: 0.875rem;
      line-height: 1.4;
    }
    .chat-bubble.me {
      background: var(--primary); color: #fff;
      border-bottom-right-radius: 4px;
      align-self: flex-end;
    }
    .chat-bubble.them {
      background: var(--light-gray); color: var(--dark);
      border-bottom-left-radius: 4px;
      align-self: flex-start;
    }
    .chat-bubble.system {
      background: rgba(245,158,11,0.1); color: #B45309;
      border: 1px solid rgba(245,158,11,0.2);
      border-radius: 10px; font-size: 0.78rem;
      align-self: center; max-width: 90%;
    }
    .bubble-meta { font-size: 0.68rem; opacity: 0.65; margin-top: 3px; }
    .chat-input-row {
      display: flex; gap: 0.5rem; padding: 1rem; border-top: 1px solid var(--light-gray);
    }
    .chat-input {
      flex: 1; padding: 0.6rem 0.9rem;
      border: 1.5px solid var(--light-gray);
      border-radius: 24px;
      font-family: 'Outfit', sans-serif; font-size: 0.875rem;
      outline: none; transition: border 0.2s;
    }
    .chat-input:focus { border-color: var(--primary); }
    .chat-send {
      background: var(--primary); color:#fff;
      border: none; border-radius: 50%;
      width: 40px; height: 40px;
      display: flex; align-items:center; justify-content:center;
      cursor: pointer; transition: background 0.2s;
      flex-shrink: 0;
    }
    .chat-send:hover { background: var(--primary-dark); }

    /* ─── ATTENDANCE TABLE ─── */
    .data-table { width: 100%; border-collapse: collapse; font-size: 0.875rem; }
    .data-table th {
      text-align: left; padding: 0.75rem 1rem;
      font-size: 0.7rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.8px;
      color: var(--gray);
      border-bottom: 2px solid var(--light-gray);
    }
    .data-table td {
      padding: 0.85rem 1rem;
      border-bottom: 1px solid #f1f5f9;
      color: var(--dark);
    }
    .data-table tr:last-child td { border-bottom: none; }
    .data-table tr:hover td { background: #f8faff; }
    .table-wrap { overflow-x: auto; }

    /* ─── PROGRESS BAR ─── */
    .progress-bar {
      height: 6px; background: var(--light-gray); border-radius: 99px; overflow: hidden;
    }
    .progress-fill { height: 100%; border-radius: 99px; transition: width 0.6s ease; }
    .progress-fill.blue { background: var(--primary); }
    .progress-fill.green { background: var(--success); }
    .progress-fill.orange { background: var(--warning); }

    /* ─── ISSUE FORM ─── */
    .issue-category {
      display: grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 0.75rem;
      margin-bottom: 1rem;
    }
    .issue-cat-btn {
      border: 1.5px solid var(--light-gray);
      border-radius: 10px; padding: 0.75rem;
      cursor: pointer; text-align: center;
      transition: all 0.2s; background: #fff;
      font-family: 'Outfit', sans-serif;
    }
    .issue-cat-btn:hover { border-color: var(--primary); color: var(--primary); }
    .issue-cat-btn.selected { border-color: var(--primary); background: rgba(0,56,255,0.06); color: var(--primary); }
    .issue-cat-icon { font-size: 1.5rem; margin-bottom: 0.3rem; }
    .issue-cat-label { font-size: 0.78rem; font-weight: 600; }

    /* ─── DAILY REPORT ─── */
    .report-section {
      background: linear-gradient(135deg, rgba(0,56,255,0.04), rgba(0,212,255,0.04));
      border: 1px solid rgba(0,56,255,0.1);
      border-radius: 12px;
      padding: 1rem;
      margin-bottom: 0.75rem;
    }
    .report-section-title {
      font-size: 0.8rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.5px;
      color: var(--primary); margin-bottom: 0.6rem;
      display: flex; align-items: center; gap: 0.4rem;
    }

    /* ─── ALERTS / NOTICES ─── */
    .alert {
      padding: 0.85rem 1rem;
      border-radius: 10px;
      font-size: 0.85rem;
      display: flex; align-items:flex-start; gap: 0.6rem;
      margin-bottom: 0.75rem;
    }
    .alert.info { background: rgba(0,56,255,0.07); color: var(--primary-dark); border-left: 3px solid var(--primary); }
    .alert.warning { background: rgba(245,158,11,0.1); color: #B45309; border-left: 3px solid var(--warning); }
    .alert.success { background: rgba(16,185,129,0.1); color: #047857; border-left: 3px solid var(--success); }

    /* ─── DIVIDER ─── */
    .divider { height: 1px; background: var(--light-gray); margin: 1rem 0; }

    /* ─── MODAL ─── */
    .modal-overlay {
      display: none; position: fixed; inset:0;
      background: rgba(10,15,28,0.6); backdrop-filter: blur(4px);
      z-index: 500; align-items:center; justify-content:center; padding: 1rem;
    }
    .modal-overlay.open { display: flex; }
    .modal {
      background: #fff; border-radius: 20px;
      padding: 1.8rem; max-width: 480px; width: 100%;
      box-shadow: 0 20px 60px rgba(0,0,0,0.2);
      animation: slideUp 0.25s ease;
    }
    @keyframes slideUp {
      from { transform: translateY(20px); opacity: 0; }
      to { transform: translateY(0); opacity: 1; }
    }
    .modal-header {
      display: flex; align-items:center; justify-content:space-between;
      margin-bottom: 1.2rem;
    }
    .modal-title { font-family:'Barlow',sans-serif; font-size:1.2rem; font-weight:800; text-transform:uppercase; }
    .modal-close {
      background: var(--light-gray); border:none; cursor:pointer;
      width:32px; height:32px; border-radius:50%;
      display:flex; align-items:center; justify-content:center;
      font-size: 1rem; color: var(--gray); transition: background 0.2s;
    }
    .modal-close:hover { background: #CBD5E1; }

    /* ─── RESPONSIVE ─── */
    @media (max-width: 768px) {
      .sidebar { transform: translateX(-100%); }
      .sidebar.mobile-open { transform: translateX(0); }
      .main { margin-left: 0; padding: 1rem; }
      .grid-2, .grid-3, .grid-4 { grid-template-columns: 1fr; }
      .clock-time { font-size: 2.8rem; }
      .topbar { padding: 0 1rem; }
      .emp-info { display: none; }
    }
    @media (max-width: 480px) {
      .clock-actions { flex-direction: column; }
      .clock-actions .btn { width: 100%; justify-content: center; }
      .task-actions { flex-direction: column; }
      .chat-container { height: 350px; }
    }
    @media (min-width: 769px) {
      .menu-btn { display: flex; }
    }

    /* ─── SCROLLBAR ─── */
    ::-webkit-scrollbar { width: 6px; height: 6px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: #CBD5E1; border-radius: 99px; }

    /* ─── TOAST ─── */
    .toast-container {
      position: fixed; bottom: 1.5rem; right: 1.5rem; z-index: 999;
      display: flex; flex-direction: column; gap: 0.5rem;
    }
    .toast {
      background: var(--dark); color: #fff;
      padding: 0.8rem 1.2rem; border-radius: 12px;
      font-size: 0.85rem; font-weight: 500;
      box-shadow: 0 4px 20px rgba(0,0,0,0.2);
      display: flex; align-items:center; gap: 0.6rem;
      animation: fadeInUp 0.3s ease;
      max-width: 300px;
    }
    .toast.success { background: var(--success); }
    .toast.error { background: var(--error); }
    @keyframes fadeInUp {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }

    /* toggle for clock in */
    .clock-btn-group { display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap; }
    .photo-upload-pair { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }

    /* summary row */
    .summary-row {
      display: flex; align-items: center; justify-content: space-between;
      padding: 0.6rem 0; border-bottom: 1px solid #f1f5f9;
      font-size: 0.875rem;
    }
    .summary-row:last-child { border-bottom: none; }
    .summary-label { color: var(--gray); font-weight: 500; }
    .summary-val { font-weight: 600; }

  </style>
</head>
