                <div style="font-weight:600;font-size:0.9rem;">Maria Domingo</div>
                <div style="font-size:0.75rem;color:var(--gray);">HR / Admin</div>
                <div style="font-size:0.78rem;color:var(--success);margin-top:2px;">📞 +639 275 105 795</div>
              </div>
            </div>
            <div style="display:flex; align-items:center; gap:1rem; padding:0.75rem; background:rgba(245,158,11,0.05); border-radius:10px; border:1px solid rgba(245,158,11,0.1);">
              <div style="width:40px;height:40px;border-radius:50%;background:var(--warning);display:flex;align-items:center;justify-content:center;color:#fff;font-weight:700;font-size:0.85rem;">DW</div>
              <div>
                <div style="font-weight:600;font-size:0.9rem;">DreamWorks HVAC</div>
                <div style="font-size:0.75rem;color:var(--gray);">Main Office — Pasig City</div>
                <div style="font-size:0.78rem;color:var(--warning);margin-top:2px;">📞 +639 275 105 794</div>
              </div>
            </div>
          </div>
        </div>

        <div class="card">
          <div class="card-title"><span class="dot"></span> My Open Issues</div>
          <div style="font-size:0.85rem; color:var(--gray); text-align:center; padding:1rem 0;">
            No open issues at the moment. ✅
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ══════════ SUBMIT TO ADMIN ══════════ -->
  <div class="page" id="page-submissions">
    <div class="page-header">
      <div class="page-title">Submit to Admin</div>
      <div class="page-sub">All required employee submissions in one place</div>
    </div>

    <div class="alert success">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
      <span>These submissions go directly to admin for review. Keep records up to date.</span>
    </div>

    <div class="grid-2">
      <!-- Leave Request -->
      <div class="card">
        <div class="card-title"><span class="dot"></span> 📅 Leave / Absence Request</div>
        <div class="form-group">
          <label class="form-label">Leave Type</label>
          <select class="form-control">
            <option>Sick Leave</option>
            <option>Vacation Leave</option>
            <option>Emergency Leave</option>
            <option>Half-Day</option>
          </select>
        </div>
        <div class="grid-2" style="gap:0.5rem;">
          <div class="form-group">
            <label class="form-label">From Date</label>
            <input type="date" class="form-control">
          </div>
          <div class="form-group">
            <label class="form-label">To Date</label>
            <input type="date" class="form-control">
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">Reason</label>
          <textarea class="form-control" placeholder="Reason for leave..."></textarea>
        </div>
        <button class="btn btn-primary" onclick="showToast('Leave request submitted ✓','success')">Submit Request</button>
      </div>

      <!-- Overtime / Expense -->
      <div class="card">
        <div class="card-title"><span class="dot"></span> ⏰ Overtime / Expense Claim</div>
        <div class="form-group">
          <label class="form-label">Type</label>
          <select class="form-control">
            <option>Overtime Request</option>
            <option>Expense Reimbursement</option>
            <option>Transportation Allowance</option>
            <option>Tool / Parts Purchase</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">Date</label>
          <input type="date" class="form-control">
        </div>
        <div class="form-group">
          <label class="form-label">Amount (PHP)</label>
          <input type="number" class="form-control" placeholder="0.00">
        </div>
        <div class="form-group">
          <label class="form-label">Attach Receipt / Proof</label>
          <div class="upload-zone" onclick="triggerUpload('receiptUploadFile')">
            <div class="upload-icon">🧾</div>
            <div class="upload-text"><strong>Upload receipt</strong></div>
            <div class="upload-preview" id="receiptUploadPreview"></div>
          </div>
          <input type="file" id="receiptUploadFile" accept="image/*" style="display:none" onchange="handlePhotoUpload(this,'receiptUploadPreview','')">
        </div>
        <button class="btn btn-primary" onclick="showToast('Claim submitted ✓','success')">Submit Claim</button>
      </div>

      <!-- Tools / Inventory -->
      <div class="card">
        <div class="card-title"><span class="dot"></span> 🔧 Tools & Parts Request</div>
        <div class="form-group">
          <label class="form-label">Items Needed</label>
          <textarea class="form-control" placeholder="List tools or parts with quantity (e.g., Freon R-410A x2, filter kit x1)..."></textarea>
        </div>
        <div class="form-group">
          <label class="form-label">Urgency</label>
          <select class="form-control">
            <option>Needed Today</option>
            <option>By Tomorrow</option>
            <option>This Week</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">For Job/Task</label>
          <input type="text" class="form-control" placeholder="Which job is this for?">
        </div>
        <button class="btn btn-outline" onclick="showToast('Parts request sent to admin ✓','success')">Send Request</button>
      </div>

      <!-- Personal Document -->
      <div class="card">
        <div class="card-title"><span class="dot"></span> 📄 Document Submission</div>
        <div class="form-group">
          <label class="form-label">Document Type</label>
          <select class="form-control">
            <option>Medical Certificate</option>
            <option>Government ID Update</option>
            <option>SSS / PhilHealth / Pag-IBIG</option>
            <option>Training Certificate</option>
            <option>Other</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">Notes / Description</label>
          <textarea class="form-control" placeholder="Any notes about this document..."></textarea>
        </div>
        <div class="form-group">
          <label class="form-label">Upload Document</label>
          <div class="upload-zone" onclick="triggerUpload('docFile')">
            <div class="upload-icon">📤</div>
            <div class="upload-text"><strong>Upload file</strong> (image or PDF)</div>
            <div class="upload-preview" id="docPreview"></div>
          </div>
          <input type="file" id="docFile" accept="image/*,.pdf" style="display:none" onchange="handlePhotoUpload(this,'docPreview','')">
        </div>
        <button class="btn btn-primary" onclick="showToast('Document submitted to admin ✓','success')">Submit Document</button>
      </div>
    </div>
  </div>

</main>

<!-- TASK DETAIL MODAL -->
<div class="modal-overlay" id="taskModal">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title">Task Details</div>
      <button class="modal-close" onclick="closeModal('taskModal')">✕</button>
    </div>
    <div>
      <div class="report-section">
        <div class="report-section-title">📍 Job Information</div>
        <div class="summary-row"><span class="summary-label">Job</span><span class="summary-val">AC Unit Repair</span></div>
        <div class="summary-row"><span class="summary-label">Location</span><span class="summary-val">Brgy. Kapasigan, Pasig</span></div>
        <div class="summary-row"><span class="summary-label">Client</span><span class="summary-val">Maria Santos</span></div>
        <div class="summary-row"><span class="summary-label">Contact</span><span class="summary-val">+639 9X XXXX XXX</span></div>
        <div class="summary-row"><span class="summary-label">Schedule</span><span class="summary-val">9:00 AM Today</span></div>
        <div class="summary-row"><span class="summary-label">Priority</span><span class="summary-val"><span class="pill red">High</span></span></div>
      </div>
      <div class="report-section">
        <div class="report-section-title">🔧 Work Instructions</div>
        <p style="font-size:0.85rem; color:var(--gray); line-height:1.6;">Inverter split-type AC unit not cooling. Inspect refrigerant levels, check compressor operation, clean filters, and test thermostat. Report findings before proceeding with any part replacement.</p>
      </div>
      <div style="display:flex; gap:0.75rem; margin-top:0.5rem;">
        <button class="btn btn-primary" onclick="closeModal('taskModal'); showToast('Task marked as In Progress','info')">Start Task</button>
        <button class="btn btn-gray" onclick="closeModal('taskModal')">Close</button>
      </div>
    </div>
  </div>
</div>

<!-- TOAST CONTAINER -->
<div class="toast-container" id="toastContainer"></div>

<script>
  // ─── CLOCK ───
  let clockedIn = false;
  let clockInTime = null;
  let elapsedInterval = null;

  function updateClocks() {
    const now = new Date();
    const timeStr = now.toLocaleTimeString('en-PH', { hour12: true });
    const dateStr = now.toLocaleDateString('en-PH', { weekday:'long', year:'numeric', month:'long', day:'numeric' });
    const shortDate = now.toLocaleDateString('en-PH', { month:'short', day:'numeric', year:'numeric' });

    const mc = document.getElementById('mainClock');
    const md = document.getElementById('mainDate');
    const dc = document.getElementById('dashClock');
    const dd = document.getElementById('dashDate');
    const sd = document.getElementById('summaryDate');

    if(mc) mc.textContent = timeStr;
    if(md) md.textContent = dateStr;
    if(dc) dc.textContent = timeStr;
    if(dd) dd.textContent = dateStr;
    if(sd && !clockedIn) sd.textContent = shortDate;
  }
  setInterval(updateClocks, 1000);
  updateClocks();

  function clockIn() {
    clockedIn = true;
    clockInTime = new Date();
    const timeStr = clockInTime.toLocaleTimeString('en-PH', { hour12: true });

    document.getElementById('clockInBtn').disabled = true;
    document.getElementById('clockInBtn').style.opacity = '0.5';
    document.getElementById('clockOutBtn').disabled = false;
    document.getElementById('clockOutBtn').style.opacity = '1';

    document.getElementById('clockIndicator').className = 'status-indicator clocked-in';
    document.getElementById('clockStatusText').textContent = 'Clocked In — Working';
    document.getElementById('clockStatusBadge').textContent = 'IN';
    document.getElementById('clockStatusBadge').className = 'badge green';

    document.getElementById('summaryIn').textContent = timeStr;
    document.getElementById('summaryStatus').textContent = 'Working';
    document.getElementById('summaryStatus').className = 'pill green';

    document.getElementById('elapsedBox').style.display = 'block';

    elapsedInterval = setInterval(() => {
      const diff = new Date() - clockInTime;
      const h = Math.floor(diff / 3600000);
      const m = Math.floor((diff % 3600000) / 60000);
      document.getElementById('elapsedVal').textContent = `${h}h ${m}m`;

      // Update dashboard stat
      const dashStat = document.querySelector('.stat-val');
      if(dashStat) dashStat.textContent = `${h}h ${m}m`;
    }, 60000);

    // Add log entry
    addLog(timeStr, 'var(--success)', `<strong>Clocked In</strong> at ${timeStr}`);
    showToast('Clock-in recorded ✓', 'success');
  }

  function clockOut() {
    clockedIn = false;
    const now = new Date();
    const timeStr = now.toLocaleTimeString('en-PH', { hour12: true });
    const diff = now - clockInTime;
    const h = Math.floor(diff / 3600000);
    const m = Math.floor((diff % 3600000) / 60000);

    clearInterval(elapsedInterval);

    document.getElementById('clockOutBtn').disabled = true;
    document.getElementById('clockOutBtn').style.opacity = '0.5';
    document.getElementById('clockStatusBadge').textContent = 'OUT';
    document.getElementById('clockStatusBadge').className = 'badge';

    document.getElementById('clockIndicator').className = 'status-indicator clocked-out';
    document.getElementById('clockStatusText').textContent = 'Clocked Out';

    document.getElementById('summaryOut').textContent = timeStr;
    document.getElementById('summaryHours').textContent = `${h}h ${m}m`;
    document.getElementById('summaryStatus').textContent = 'Completed';
    document.getElementById('summaryStatus').className = 'pill green';

    addLog(timeStr, 'var(--primary)', `<strong>Clocked Out</strong> at ${timeStr} — Total: ${h}h ${m}m`);
    showToast('Clock-out recorded. Great work today!', 'success');
  }

  function handleClockIn() {
    showPage('timeclock', document.querySelector('[onclick*=timeclock]'));
    setTimeout(clockIn, 300);
  }

  function addLog(time, color, text) {
    const log = document.getElementById('activityLog');
    const item = document.createElement('div');
    item.className = 'log-item';
    item.innerHTML = `<div class="log-time">${time}</div><div class="log-dot" style="background:${color}"></div><div class="log-text">${text}</div>`;
    log.appendChild(item);
  }

  // ─── NAVIGATION ───
  function showPage(id, btn) {
    document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
    document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
    const page = document.getElementById('page-' + id);
    if(page) page.classList.add('active');
    if(btn) btn.classList.add('active');
    // Close sidebar on mobile
    if(window.innerWidth < 769) {
      document.getElementById('sidebar').classList.remove('mobile-open');
      document.getElementById('sidebarOverlay').classList.remove('visible');
    }
    window.scrollTo(0,0);
  }

  // ─── SIDEBAR TOGGLE ───
  let sidebarOpen = true;
  function toggleSidebar() {
    const sb = document.getElementById('sidebar');
    const main = document.getElementById('main');
    const overlay = document.getElementById('sidebarOverlay');
    if(window.innerWidth < 769) {
      sb.classList.toggle('mobile-open');
      overlay.classList.toggle('visible');
    } else {
      sidebarOpen = !sidebarOpen;
      if(sidebarOpen) {
        sb.style.transform = '';
        main.style.marginLeft = 'var(--sidebar-w)';
      } else {
        sb.style.transform = 'translateX(-100%)';
        main.style.marginLeft = '0';
      }
    }
  }

  // ─── PHOTO UPLOAD ───
  function triggerUpload(id) { document.getElementById(id).click(); }
  function handlePhotoUpload(input, previewId, zoneId) {
    const preview = document.getElementById(previewId);
    if(!preview) return;
    if(zoneId) {
      const zone = document.getElementById(zoneId);
      if(zone) zone.classList.add('has-file');
    }
    Array.from(input.files).forEach(file => {
      const reader = new FileReader();
      reader.onload = e => {
        const thumb = document.createElement('div');
        thumb.className = 'preview-thumb';
        thumb.innerHTML = `<img src="${e.target.result}" alt="upload"><button class="remove" onclick="this.parentElement.remove()">✕</button>`;
        preview.appendChild(thumb);
      };
      reader.readAsDataURL(file);
    });
    showToast(`${input.files.length} photo(s) ready to upload`, 'success');
  }

  // ─── TASK TOGGLE ───
  function toggleTask(chkId, taskId) {
    const chk = document.getElementById(chkId);
    const task = document.getElementById(taskId);
    chk.classList.toggle('done');
    if(chk.classList.contains('done')) {
      chk.innerHTML = '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>';
      task.style.opacity = '0.55';
      showToast('Task marked as complete ✓', 'success');
    } else {
      chk.innerHTML = '';
      task.style.opacity = '1';
    }
  }

  // ─── ISSUE CATEGORY ───
  function selectCat(el) {
    document.querySelectorAll('.issue-cat-btn').forEach(b => b.classList.remove('selected'));
    el.classList.add('selected');
  }

  // ─── CHAT ───
  function sendChat() {
    const input = document.getElementById('chatInput');
    const msg = input.value.trim();
    if(!msg) return;
    const messages = document.getElementById('chatMessages');
    const bubble = document.createElement('div');
    bubble.className = 'chat-bubble me';
    const t = new Date().toLocaleTimeString('en-PH', { hour:'numeric', minute:'2-digit', hour12:true });
    bubble.innerHTML = `${msg}<div class="bubble-meta">You · ${t}</div>`;
    messages.appendChild(bubble);
    messages.scrollTop = messages.scrollHeight;
    input.value = '';
  }

  // ─── MODAL ───
  function openTaskDetail() { document.getElementById('taskModal').classList.add('open'); }
  function closeModal(id) { document.getElementById(id).classList.remove('open'); }

  // ─── TOAST ───
  function showToast(msg, type = 'info') {
    const container = document.getElementById('toastContainer');
    const icons = { success:'✅', error:'❌', info:'ℹ️' };
    const toast = document.createElement('div');
    toast.className = `toast ${type}`;
    toast.innerHTML = `<span>${icons[type]||'💬'}</span><span>${msg}</span>`;
    container.appendChild(toast);
    setTimeout(() => toast.remove(), 3500);
  }

  // ─── SET TODAY DATE IN REPORT ───
  document.getElementById('reportDate').valueAsDate = new Date();
</script>
</body>
</html>
