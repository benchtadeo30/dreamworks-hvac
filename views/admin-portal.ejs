<script data-cfasync="false" src="/cdn-cgi/scripts/5c5dd728/cloudflare-static/email-decode.min.js"></script><script>
    /* =========================================================
       CLOCK
    ========================================================= */
    function updateClock() {
        const now = new Date();
        document.getElementById('topbarClock').textContent =
            now.toLocaleTimeString('en-PH', { hour: '2-digit', minute: '2-digit', hour12: true });
    }
    updateClock();
    setInterval(updateClock, 30000);

    /* =========================================================
       SIDEBAR VIEW SWITCHING
    ========================================================= */
    function showView(viewId, linkEl) {
        document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
        document.querySelectorAll('.sidebar-link').forEach(l => l.classList.remove('active'));
        document.getElementById('view-' + viewId).classList.add('active');
        if (linkEl) linkEl.classList.add('active');
        // Re-render attendance calendar after the view becomes visible
        if (viewId === 'attendance') {
            requestAnimationFrame(() => renderAttCalendar());
        }
    }

    function filterAndShow(status) {
        showView('clients', null);
        setFilter(status, document.querySelector(`.filter-pill[data-filter="${status}"]`));
        document.querySelectorAll('.sidebar-link').forEach(l => l.classList.remove('active'));
    }

    /* =========================================================
       CLIENT FILTER & SEARCH
    ========================================================= */
    function setFilter(status, el) {
        document.querySelectorAll('.filter-pill').forEach(p => p.classList.remove('active'));
        if (el) el.classList.add('active');
        document.querySelectorAll('.client-card').forEach(card => {
            const match = status === 'all' || card.dataset.status === status;
            card.style.display = match ? '' : 'none';
        });
    }

    function filterClients() {
        const q = document.getElementById('clientSearch').value.toLowerCase();
        document.querySelectorAll('.client-card').forEach(card => {
            card.style.display = card.dataset.name.includes(q) ? '' : 'none';
        });
    }

    function toggleClient(id) {
        const card = document.getElementById(id);
        card.classList.toggle('expanded');
    }

    function switchDropTab(btn, panelId) {
        const dropdown = btn.closest('.client-dropdown');
        dropdown.querySelectorAll('.dropdown-tab').forEach(t => t.classList.remove('active'));
        dropdown.querySelectorAll('.dropdown-panel').forEach(p => p.classList.remove('active'));
        btn.classList.add('active');
        document.getElementById(panelId).classList.add('active');
    }

    /* =========================================================
       TABLE SEARCH FILTER
    ========================================================= */
    function filterTable(input, tableId) {
        const q = input.value.toLowerCase();
        document.querySelectorAll(`#${tableId} tbody tr`).forEach(row => {
            row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
        });
    }

    /* =========================================================
       FILE UPLOAD HANDLERS — Employee & Customer
    ========================================================= */
    function handleFileSelect(input, listId, prefix) {
        if (input.files.length) addFilesToList(input.files, listId, prefix);
    }

    function handleDrop(e, listId, prefix) {
        e.preventDefault();
        const zone = e.currentTarget;
        zone.style.borderColor = ''; zone.style.background = '';
        if (e.dataTransfer.files.length) addFilesToList(e.dataTransfer.files, listId, prefix);
    }

    function addFilesToList(files, listId, prefix) {
        const fbId = prefix === 'emp' ? 'empUploadFeedback' : 'custUploadFeedback';
        const fb = document.getElementById(fbId);
        fb.style.display = 'block';
        fb.textContent = `✅ ${files.length} file(s) added: ${Array.from(files).map(f => f.name).join(', ')}`;
        setTimeout(() => { fb.style.display = 'none'; }, 4000);

        const extIcons = {PDF:'📄', JPG:'🖼️', JPEG:'🖼️', PNG:'🖼️', DOCX:'📝', XLSX:'📊'};
        const list = document.getElementById(listId);
        Array.from(files).forEach(file => {
            const ext = file.name.split('.').pop().toUpperCase();
            const icon = extIcons[ext] || '📁';
            const item = document.createElement('div');
            item.className = 'file-item';
            item.dataset.filetype = 'other';
            item.style.animation = 'fadeInUp 0.3s ease';
            item.innerHTML = `
                <div class="file-icon">${icon}</div>
                <div class="file-info">
                    <div class="file-name">${file.name}</div>
                    <div class="file-meta">Just uploaded · ${(file.size/1024).toFixed(0)} KB · ${new Date().toLocaleDateString('en-PH',{month:'short',day:'numeric',year:'numeric'})}</div>
                </div>
                <span class="badge badge-blue">New</span>
                <div style="display:flex;gap:0.4rem;margin-left:auto;">
                    <button class="btn btn-ghost btn-sm">👁 View</button>
                    <button class="btn btn-ghost btn-sm">⬇ Download</button>
                    <button class="btn btn-danger btn-sm" onclick="deleteFile(this)">🗑</button>
                </div>`;
            list.prepend(item);
        });
    }

    function deleteFile(btn) {
        if (confirm('Delete this file?')) {
            btn.closest('.file-item').style.animation = 'fadeOut 0.25s ease forwards';
            setTimeout(() => btn.closest('.file-item').remove(), 250);
        }
    }

    function filterFileList(listId, query) {
        const q = query.toLowerCase();
        document.querySelectorAll(`#${listId} .file-item`).forEach(item => {
            item.style.display = item.textContent.toLowerCase().includes(q) ? '' : 'none';
        });
    }

    function filterFileListCat(listId, cat) {
        document.querySelectorAll(`#${listId} .file-item`).forEach(item => {
            item.style.display = cat === 'all' || item.dataset.filetype === cat ? '' : 'none';
        });
    }

    // Legacy — keep so nothing breaks if referenced elsewhere
    function filterFiles(cat) {
        filterFileListCat('empFileList', cat);
        filterFileListCat('custFileList', cat);
    }

    /* =========================================================
       ATTENDANCE CALENDAR — linked to real computer date
    ========================================================= */
    const TODAY = new Date();
    let calYear  = TODAY.getFullYear();
    let calMonth = TODAY.getMonth();

    const STATUS_POOL = ['present','present','present','present','present','late','absent'];
    const ATT_DATA = {};

    function getStatus(emp, date) {
        const d = date.getDay();
        if (d === 0 || d === 6) return 'off';
        if (date > TODAY) return 'future';
        const key = `${emp}_${date.getFullYear()}_${date.getMonth()}_${date.getDate()}`;
        if (!ATT_DATA[key]) {
            if (emp === 'torres' && date.getFullYear()===2026 && date.getMonth()===3 && date.getDate()>=7 && date.getDate()<=11) {
                ATT_DATA[key] = 'leave';
            } else if (emp === 'lim' && date.toDateString() === TODAY.toDateString()) {
                ATT_DATA[key] = 'absent';
            } else {
                let hash = 0;
                for (let c of key) hash = (hash * 31 + c.charCodeAt(0)) & 0xffffffff;
                ATT_DATA[key] = STATUS_POOL[Math.abs(hash) % STATUS_POOL.length];
            }
        }
        return ATT_DATA[key];
    }

    function statusClass(s) {
        return {present:'att-present',late:'att-late',absent:'att-absent',off:'att-off',leave:'att-leave',future:'att-future'}[s] || 'att-off';
    }
    function statusLabel(s) {
        return {present:'Present ✅',late:'Late ⏰',absent:'Absent ❌',off:'Day Off 💤',leave:'On Leave 🏖️',future:'No data yet'}[s] || s;
    }

    function renderAttCalendar() {
        const empEl = document.getElementById('calEmpSelect');
        const emp = empEl ? empEl.value : 'santos';
        const monthNames = ['January','February','March','April','May','June','July','August','September','October','November','December'];
        const lbl = document.getElementById('calMonthLabel');
        if (lbl) lbl.textContent = `${monthNames[calMonth]} ${calYear}`;

        const nextBtn = document.getElementById('calNextBtn');
        const isCurrentMonth = calYear === TODAY.getFullYear() && calMonth === TODAY.getMonth();
        if (nextBtn) { nextBtn.disabled = isCurrentMonth; nextBtn.style.opacity = isCurrentMonth ? '0.3' : '1'; nextBtn.style.cursor = isCurrentMonth ? 'not-allowed' : 'pointer'; }

        const grid = document.getElementById('calGrid');
        if (!grid) return;

        // Always rebuild from scratch — day-labels are re-inserted first
        grid.innerHTML = '';
        ['M','T','W','T','F','S','S'].forEach(d => {
            const lbl = document.createElement('div');
            lbl.className = 'att-day-label';
            lbl.textContent = d;
            grid.appendChild(lbl);
        });

        const firstDay = new Date(calYear, calMonth, 1);
        const daysInMonth = new Date(calYear, calMonth + 1, 0).getDate();
        let startOffset = firstDay.getDay();
        startOffset = startOffset === 0 ? 6 : startOffset - 1;

        for (let i = 0; i < startOffset; i++) {
            const blank = document.createElement('div');
            blank.className = 'att-cell att-empty';
            grid.appendChild(blank);
        }

        let counts = {present:0,late:0,absent:0,off:0,leave:0};
        for (let day = 1; day <= daysInMonth; day++) {
            const date = new Date(calYear, calMonth, day);
            const status = getStatus(emp, date);
            if (status !== 'future' && counts[status] !== undefined) counts[status]++;

            const cell = document.createElement('div');
            const isToday = date.toDateString() === TODAY.toDateString();
            cell.className = `att-cell ${statusClass(status)}${isToday ? ' att-today' : ''}`;
            cell.textContent = day;
            cell.title = `${monthNames[calMonth]} ${day}, ${calYear} — ${statusLabel(status)}`;

            cell.addEventListener('mouseenter', () => {
                const tip = document.getElementById('calTooltip');
                if (tip) { tip.style.display='block'; tip.innerHTML=`<strong style="color:var(--white)">${monthNames[calMonth]} ${day}, ${calYear}</strong> &nbsp; ${statusLabel(status)}`; }
            });
            cell.addEventListener('mouseleave', () => {
                const tip = document.getElementById('calTooltip');
                if (tip) tip.style.display='none';
            });

            if (status !== 'future' && status !== 'off') {
                cell.style.cursor = 'pointer';
                cell.addEventListener('click', () => {
                    const iso = `${calYear}-${String(calMonth+1).padStart(2,'0')}-${String(day).padStart(2,'0')}`;
                    const picker = document.getElementById('attDatePicker');
                    if (picker) { picker.value = iso; updateLogDate(iso); }
                });
            }
            grid.appendChild(cell);
        }

        const summary = document.getElementById('calSummary');
        if (summary) summary.innerHTML = `
            <span class="badge badge-green">✅ Present: ${counts.present}</span>
            <span class="badge badge-yellow">⏰ Late: ${counts.late}</span>
            <span class="badge badge-red">❌ Absent: ${counts.absent}</span>
            <span class="badge badge-blue">🏖️ Leave: ${counts.leave}</span>
            <span class="badge badge-gray">💤 Off: ${counts.off}</span>`;
    }

    function calNavMonth(dir) {
        calMonth += dir;
        if (calMonth > 11) { calMonth = 0; calYear++; }
        if (calMonth < 0)  { calMonth = 11; calYear--; }
        if (calYear > TODAY.getFullYear() || (calYear === TODAY.getFullYear() && calMonth > TODAY.getMonth())) {
            calMonth = TODAY.getMonth(); calYear = TODAY.getFullYear();
        }
        renderAttCalendar();
    }

    function calGoToday() {
        calYear = TODAY.getFullYear(); calMonth = TODAY.getMonth();
        renderAttCalendar();
        const iso = TODAY.toISOString().split('T')[0];
        const picker = document.getElementById('attDatePicker');
        if (picker) { picker.value = iso; updateLogDate(iso); }
    }

    function updateLogDate(iso) {
        if (!iso) return;
        const d = new Date(iso + 'T00:00:00');
        const label = d.toLocaleDateString('en-PH', {weekday:'long', year:'numeric', month:'long', day:'numeric'});
        const el = document.getElementById('attTodayDate');
        if (el) el.textContent = label;
    }

    // Add today-highlight style
    (function addCalStyles() {
        const s = document.createElement('style');
        s.textContent = `.att-today { outline: 2px solid var(--accent); outline-offset: 1px; } .att-leave { background: rgba(59,130,246,0.15); color: var(--info); } .att-future { background: rgba(255,255,255,0.03); color: rgba(255,255,255,0.15); cursor: default; }`;
        document.head.appendChild(s);
    })();

    /* =========================================================
       LOGOUT
    ========================================================= */
    function openLogoutModal() {
        document.getElementById('logoutModal').classList.add('open');
    }
    function closeLogoutModal() {
        document.getElementById('logoutModal').classList.remove('open');
    }
    function doLogout() {
        // Redirect to login page or show a simple message
        window.location.href = '/';
    }

    /* =========================================================
       DETAIL VIEW MODAL
    ========================================================= */
    function openDetailModal(title, subtitle, details) {
        document.getElementById('modalTitle').textContent = title;
        document.getElementById('modalSubtitle').textContent = subtitle || '';
        const grid = document.getElementById('modalDetailGrid');
        grid.innerHTML = details.map(d => `
            <div class="modal-detail-item">
                <div class="modal-detail-label">${d.label}</div>
                <div class="modal-detail-value">${d.value}</div>
            </div>`).join('');
        document.getElementById('detailModal').classList.add('open');
    }
    function closeDetailModal() {
        document.getElementById('detailModal').classList.remove('open');
    }

    // Close modals when clicking overlay background
    document.addEventListener('click', function(e) {
        if (e.target.id === 'detailModal') closeDetailModal();
        if (e.target.id === 'logoutModal') closeLogoutModal();
    });

    // Close modals on Escape key
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') { closeDetailModal(); closeLogoutModal(); }
    });

    // Data maps for employee and service/project View buttons
    const EMP_DATA = {
        'EMP-001': { name: 'Ricardo Santos', role: 'Senior Engineer', status: '● On-Field', assignment: 'Juan Dela Cruz — AC Install', performance: '92%', jobs: '34', since: 'Jan 2022', contact: '+63 917 001 0001' },
        'EMP-002': { name: 'Maria Reyes',    role: 'Technician',       status: '● On-Field', assignment: 'Angela Reyes — Maintenance', performance: '88%', jobs: '27', since: 'Mar 2022', contact: '+63 917 002 0002' },
        'EMP-003': { name: 'Jose Cruz',      role: 'Engineer',         status: '● In Office', assignment: '—',                         performance: '79%', jobs: '19', since: 'Jun 2022', contact: '+63 917 003 0003' },
        'EMP-004': { name: 'Ana Torres',     role: 'Technician',       status: '● On Leave',  assignment: '—',                         performance: '83%', jobs: '22', since: 'Aug 2022', contact: '+63 917 004 0004' },
        'EMP-005': { name: 'Ben Manalo',     role: 'Senior Technician',status: '● On-Field', assignment: 'Marco Villanueva — Cold Room', performance: '95%', jobs: '41', since: 'Oct 2021', contact: '+63 917 005 0005' },
    };

    // Wire up all "View" buttons in the employee table on page load
    document.addEventListener('DOMContentLoaded', function() {

        // ── File items: Employee Files & Customer Files ──
        document.querySelectorAll('.file-item').forEach(function(item) {
            const viewBtn = Array.from(item.querySelectorAll('button')).find(b => b.textContent.trim().includes('View'));
            if (!viewBtn) return;
            viewBtn.addEventListener('click', function(e) {
                e.stopPropagation();
                const nameEl  = item.querySelector('.file-name');
                const metaEl  = item.querySelector('.file-meta');
                const badgeEl = item.querySelector('.badge');
                const fileName = nameEl ? nameEl.textContent.trim() : 'File';
                const meta     = metaEl ? metaEl.textContent.trim() : '';
                const parts    = meta.split('·').map(s => s.trim());
                const details  = [];
                if (parts[0]) details.push({ label: 'Uploaded By', value: parts[0].replace(/^Uploaded by\s*/i,'').replace(/^Generated by\s*/i,'') });
                if (parts[1]) details.push({ label: 'Date',   value: parts[1] });
                if (parts[2]) details.push({ label: 'Size',   value: parts[2] });
                if (parts[3]) details.push({ label: 'Type',   value: parts[3] });
                if (badgeEl)  details.push({ label: 'Status', value: badgeEl.textContent.trim() });
                openDetailModal(fileName, 'File Preview', details);
            });
        });

        document.querySelectorAll('#empTable tbody tr').forEach(function(row) {
            const idEl = row.querySelector('[style*="0.72rem"]');
            const empId = idEl ? idEl.textContent.trim() : null;
            const viewBtn = Array.from(row.querySelectorAll('button')).find(b => b.textContent.trim() === 'View');
            if (viewBtn && empId && EMP_DATA[empId]) {
                viewBtn.addEventListener('click', function() {
                    const d = EMP_DATA[empId];
                    openDetailModal(d.name, empId + ' · ' + d.role, [
                        { label: 'Status',      value: d.status },
                        { label: 'Performance', value: d.performance },
                        { label: 'Jobs Done',   value: d.jobs },
                        { label: 'Assignment',  value: d.assignment },
                        { label: 'Since',       value: d.since },
                        { label: 'Contact',     value: d.contact },
                    ]);
                });
            }
        });

        // Wire up service/project "View" buttons inside client entry-items
        document.querySelectorAll('.entry-item').forEach(function(item) {
            const btns = Array.from(item.querySelectorAll('button'));
            const viewBtn = btns.find(b => b.textContent.trim() === 'View');
            if (viewBtn) {
                viewBtn.addEventListener('click', function(e) {
                    e.stopPropagation();
                    const titleEl = item.querySelector('.entry-title');
                    const subEl   = item.querySelector('.entry-sub');
                    const statusEl= item.querySelector('.entry-status');
                    const dateEl  = item.querySelector('.entry-date');
                    const title   = titleEl ? titleEl.textContent : 'Service / Project';
                    const sub     = subEl   ? subEl.textContent   : '';
                    const status  = statusEl? statusEl.textContent.trim() : '—';
                    const date    = dateEl  ? dateEl.textContent.trim()   : '—';
                    const phaseLbl= item.querySelector('.ep-label span:first-child');
                    const phasePct= item.querySelector('.ep-label span:last-child');
                    const details = [
                        { label: 'Status',  value: status },
                        { label: 'Details', value: sub },
                    ];
                    if (phaseLbl) details.push({ label: 'Phase',    value: phaseLbl.textContent });
                    if (phasePct) details.push({ label: 'Progress', value: phasePct.textContent });
                    if (date && date !== '—') details.push({ label: 'Date', value: date });
                    openDetailModal(title, '', details);
                });
            }
        });

        // Leave request "View" buttons
        document.querySelectorAll('table tbody tr').forEach(function(row) {
            const cells = row.querySelectorAll('td');
            const viewBtn = Array.from(row.querySelectorAll('button')).find(b => b.textContent.trim() === 'View');
            if (viewBtn && cells.length >= 6) {
                viewBtn.addEventListener('click', function() {
                    openDetailModal('Leave Request — ' + (cells[0] ? cells[0].textContent.trim() : ''), '', [
                        { label: 'Type',   value: cells[1] ? cells[1].textContent.trim() : '—' },
                        { label: 'From',   value: cells[2] ? cells[2].textContent.trim() : '—' },
                        { label: 'To',     value: cells[3] ? cells[3].textContent.trim() : '—' },
                        { label: 'Days',   value: cells[4] ? cells[4].textContent.trim() : '—' },
                        { label: 'Reason', value: cells[5] ? cells[5].textContent.trim() : '—' },
                    ]);
                });
            }
        });
    });

    // Init on page load — calendar renders when attendance tab is clicked
    (function initAttendance() {
        const picker = document.getElementById('attDatePicker');
        const iso = TODAY.toISOString().split('T')[0];
        if (picker) { picker.value = iso; picker.max = iso; }
        updateLogDate(iso);
        // Don't call renderAttCalendar() here — view is hidden, grid labels would be lost
    })();

    /* =========================================================
       EMPLOYEE SUBMISSIONS — SUB TAB SWITCHING
    ========================================================= */
    function switchSubTab(tabId, btnEl) {
        document.querySelectorAll('.sub-tab').forEach(b => {
            b.style.color = 'var(--text-muted)';
            b.style.borderBottom = '2px solid transparent';
        });
        document.querySelectorAll('.sub-panel').forEach(p => p.style.display = 'none');
        btnEl.style.color = 'var(--accent)';
        btnEl.style.borderBottom = '2px solid var(--accent)';
        const panel = document.getElementById('sub-' + tabId);
        if (panel) panel.style.display = 'block';
    }

    function markAllReviewed() {
        document.querySelectorAll('#view-emp-submissions .badge-yellow').forEach(b => {
            b.className = 'badge badge-green';
            b.textContent = '✓ Reviewed';
        });
        const pendingVal = document.querySelector('#view-emp-submissions .dss-card-value');
        if (pendingVal) pendingVal.textContent = '0';
    }

    function approveLeave(btn) {
        const row = btn.closest('tr');
        const cell = row.querySelector('td:last-child');
        cell.innerHTML = '<span class="badge badge-green">✓ Approved</span>';
    }

    function denyLeave(btn) {
        const row = btn.closest('tr');
        const cell = row.querySelector('td:last-child');
        cell.innerHTML = '<span class="badge badge-red">✗ Denied</span>';
    }

    function handleAdminUpload(input) {
        const fb = document.getElementById('adminPhotoFeedback');
        fb.style.display = 'block';
        fb.textContent = `✅ ${input.files.length} photo(s) uploaded successfully.`;
        setTimeout(() => { fb.style.display = 'none'; }, 3500);
    }

    function handleAdminDocUpload(input) {
        const fb = document.getElementById('adminDocFeedback');
        fb.style.display = 'block';
        fb.textContent = `✅ ${input.files.length} document(s) uploaded successfully.`;
        setTimeout(() => { fb.style.display = 'none'; }, 3500);
    }

</script>
</body>
</html>