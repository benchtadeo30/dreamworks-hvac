<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Portal — DreamWorks HVAC</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Barlow:ital,wght@0,400;0,600;0,700;0,800;1,800&family=DM+Mono:wght@400;500&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
        --bg:         #0B0F1A;
        --surface:    #111827;
        --surface2:   #1A2236;
        --surface3:   #1F2D45;
        --border:     rgba(255,255,255,0.07);
        --border2:    rgba(255,255,255,0.12);
        --primary:    #0052FF;
        --primary-glow: rgba(0,82,255,0.35);
        --accent:     #00D4FF;
        --white:      #FFFFFF;
        --text:       #E2E8F0;
        --text-muted: #64748B;
        --text-dim:   #94A3B8;
        --success:    #10B981;
        --success-bg: rgba(16,185,129,0.12);
        --warning:    #F59E0B;
        --warning-bg: rgba(245,158,11,0.12);
        --danger:     #EF4444;
        --danger-bg:  rgba(239,68,68,0.12);
        --info:       #3B82F6;
        --info-bg:    rgba(59,130,246,0.12);
    }

    body {
        font-family: 'Outfit', sans-serif;
        background: var(--bg);
        color: var(--text);
        min-height: 100vh;
        overflow-x: hidden;
    }

    /* ===================== LAYOUT ===================== */
    .admin-layout {
        display: grid;
        grid-template-columns: 260px 1fr;
        grid-template-rows: auto 1fr;
        min-height: 100vh;
    }

    /* ===================== TOPBAR ===================== */
    .topbar {
        grid-column: 1 / -1;
        background: var(--surface);
        border-bottom: 1px solid var(--border);
        padding: 0 2rem;
        height: 64px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        position: sticky;
        top: 0;
        z-index: 200;
        backdrop-filter: blur(10px);
    }

    .topbar-left {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .admin-brand {
        font-family: 'Barlow', sans-serif;
        font-size: 1.5rem;
        font-weight: 800;
        color: var(--white);
        text-transform: uppercase;
        letter-spacing: -0.5px;
        text-decoration: none;
    }

    .admin-brand span { color: var(--accent); }

    .admin-badge {
        background: linear-gradient(135deg, var(--primary), var(--accent));
        color: #fff;
        font-size: 0.65rem;
        font-weight: 800;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        padding: 3px 9px;
        border-radius: 6px;
    }

    .topbar-right {
        display: flex;
        align-items: center;
        gap: 1.5rem;
    }

    .topbar-clock {
        font-family: 'DM Mono', monospace;
        font-size: 0.82rem;
        color: var(--text-muted);
    }

    .admin-avatar {
        width: 36px; height: 36px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--primary), var(--accent));
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
        font-size: 0.85rem;
        color: #fff;
        cursor: pointer;
        border: 2px solid rgba(255,255,255,0.15);
    }

    .topbar-name {
        font-size: 0.88rem;
        font-weight: 600;
        color: var(--text);
    }

    .topbar-role {
        font-size: 0.75rem;
        color: var(--text-muted);
    }

    .topbar-info { text-align: right; }

    .client-portal-link {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        font-size: 0.82rem;
        font-weight: 600;
        color: var(--text-muted);
        text-decoration: none;
        padding: 0.4rem 0.9rem;
        border-radius: 8px;
        border: 1px solid var(--border2);
        transition: all 0.2s;
    }

    .client-portal-link:hover {
        color: var(--accent);
        border-color: var(--accent);
        background: rgba(0,212,255,0.06);
    }

    /* ===================== SIDEBAR ===================== */
    .sidebar {
        background: var(--surface);
        border-right: 1px solid var(--border);
        padding: 1.5rem 0;
        position: sticky;
        top: 64px;
        height: calc(100vh - 64px);
        overflow-y: auto;
        scrollbar-width: thin;
        scrollbar-color: var(--border2) transparent;
    }

    .sidebar-section-label {
        font-size: 0.68rem;
        font-weight: 700;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        color: var(--text-muted);
        padding: 0 1.4rem;
        margin-bottom: 0.5rem;
        margin-top: 1.5rem;
    }

    .sidebar-section-label:first-child { margin-top: 0; }

    .sidebar-link {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.68rem 1.4rem;
        font-size: 0.9rem;
        font-weight: 500;
        color: var(--text-muted);
        cursor: pointer;
        transition: all 0.2s;
        border-left: 3px solid transparent;
        text-decoration: none;
    }

    .sidebar-link:hover {
        color: var(--text);
        background: rgba(255,255,255,0.04);
    }

    .sidebar-link.active {
        color: var(--accent);
        background: rgba(0,212,255,0.06);
        border-left-color: var(--accent);
    }

    .sidebar-icon { font-size: 1rem; width: 20px; text-align: center; }

    .sidebar-count {
        margin-left: auto;
        background: var(--primary);
        color: #fff;
        font-size: 0.7rem;
        font-weight: 700;
        padding: 2px 7px;
        border-radius: 20px;
        min-width: 20px;
        text-align: center;
    }

    .sidebar-count.warn { background: var(--warning); color: #000; }
    .sidebar-count.success { background: var(--success); }

    /* ===================== MAIN ===================== */
    .main-content {
        padding: 2rem;
        overflow-y: auto;
    }

    /* ===================== VIEWS ===================== */
    .view { display: none; animation: fadeInUp 0.3s ease; }
    .view.active { display: block; }

    /* ===================== PAGE HEADER ===================== */
    .page-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        margin-bottom: 2rem;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .page-header h1 {
        font-family: 'Barlow', sans-serif;
        font-size: 1.9rem;
        font-weight: 800;
        color: var(--white);
        letter-spacing: -0.5px;
        line-height: 1.2;
    }

    .page-header p {
        font-size: 0.88rem;
        color: var(--text-muted);
        margin-top: 0.3rem;
    }

    .page-header-actions {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
    }

    /* ===================== STAT CARDS ===================== */
    .stats-row {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1rem;
        margin-bottom: 2rem;
    }

    .stat-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 1.3rem 1.4rem;
        position: relative;
        overflow: hidden;
        transition: border-color 0.25s;
    }

    .stat-card:hover { border-color: var(--border2); }

    .stat-card::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 3px;
        border-radius: 14px 14px 0 0;
    }

    .stat-card.s-blue::before   { background: linear-gradient(90deg, var(--primary), var(--accent)); }
    .stat-card.s-green::before  { background: linear-gradient(90deg, var(--success), #34D399); }
    .stat-card.s-yellow::before { background: linear-gradient(90deg, var(--warning), #FCD34D); }
    .stat-card.s-red::before    { background: linear-gradient(90deg, var(--danger), #F87171); }

    .stat-label {
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.8px;
        text-transform: uppercase;
        color: var(--text-muted);
        margin-bottom: 0.6rem;
    }

    .stat-value {
        font-family: 'Barlow', sans-serif;
        font-size: 2.2rem;
        font-weight: 800;
        color: var(--white);
        line-height: 1;
        margin-bottom: 0.3rem;
    }

    .stat-sub {
        font-size: 0.78rem;
        color: var(--text-muted);
    }

    .stat-icon {
        position: absolute;
        top: 1.2rem; right: 1.2rem;
        font-size: 1.6rem;
        opacity: 0.25;
    }

    /* ===================== SEARCH / FILTER BAR ===================== */
    .filter-bar {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 1.5rem;
        flex-wrap: wrap;
    }

    .search-box {
        flex: 1;
        min-width: 220px;
        position: relative;
    }

    .search-box input {
        width: 100%;
        background: var(--surface);
        border: 1px solid var(--border2);
        border-radius: 10px;
        padding: 0.65rem 1rem 0.65rem 2.5rem;
        font-family: 'Outfit', sans-serif;
        font-size: 0.9rem;
        color: var(--text);
        outline: none;
        transition: border-color 0.2s;
    }

    .search-box input::placeholder { color: var(--text-muted); }
    .search-box input:focus { border-color: var(--primary); }

    .search-box .search-icon {
        position: absolute;
        left: 0.85rem;
        top: 50%;
        transform: translateY(-50%);
        color: var(--text-muted);
        font-size: 0.9rem;
        pointer-events: none;
    }

    .filter-pill {
        padding: 0.6rem 1.1rem;
        border-radius: 50px;
        border: 1px solid var(--border2);
        background: var(--surface);
        color: var(--text-muted);
        font-family: 'Outfit', sans-serif;
        font-size: 0.83rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        white-space: nowrap;
    }

    .filter-pill:hover { color: var(--text); border-color: var(--border2); background: var(--surface2); }
    .filter-pill.active { background: var(--primary); color: #fff; border-color: var(--primary); box-shadow: 0 0 14px var(--primary-glow); }

    /* ===================== CLIENT CARDS ===================== */
    .clients-list {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .client-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 16px;
        overflow: hidden;
        transition: all 0.25s;
    }

    .client-card:hover { border-color: var(--border2); }
    .client-card.expanded { border-color: rgba(0,82,255,0.4); box-shadow: 0 0 0 1px rgba(0,82,255,0.15), 0 8px 30px rgba(0,0,0,0.25); }

    /* Client row (the clickable header) */
    .client-row {
        display: grid;
        grid-template-columns: 44px 1fr auto auto auto auto;
        align-items: center;
        gap: 1rem;
        padding: 1.1rem 1.4rem;
        cursor: pointer;
        user-select: none;
        transition: background 0.2s;
    }

    .client-row:hover { background: rgba(255,255,255,0.02); }

    .client-avatar {
        width: 44px; height: 44px;
        border-radius: 12px;
        background: linear-gradient(135deg, var(--primary), var(--accent));
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: 'Barlow', sans-serif;
        font-weight: 800;
        font-size: 1rem;
        color: #fff;
        flex-shrink: 0;
    }

    .client-info { min-width: 0; }

    .client-name {
        font-weight: 700;
        font-size: 0.97rem;
        color: var(--white);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .client-meta {
        font-size: 0.78rem;
        color: var(--text-muted);
        margin-top: 0.2rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .client-tag {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.3rem 0.75rem;
        border-radius: 8px;
        font-size: 0.75rem;
        font-weight: 700;
        white-space: nowrap;
    }

    .client-tag.pending  { background: var(--warning-bg);  color: var(--warning); }
    .client-tag.ongoing  { background: var(--info-bg);     color: var(--info); }
    .client-tag.done     { background: var(--success-bg);  color: var(--success); }
    .client-tag.none     { background: rgba(255,255,255,0.05); color: var(--text-muted); }

    .client-date {
        font-family: 'DM Mono', monospace;
        font-size: 0.75rem;
        color: var(--text-muted);
        white-space: nowrap;
    }

    .client-chevron {
        color: var(--text-muted);
        font-size: 0.85rem;
        transition: transform 0.3s ease;
        flex-shrink: 0;
    }

    .client-card.expanded .client-chevron { transform: rotate(180deg); }

    /* ===================== CLIENT DROPDOWN PANEL ===================== */
    .client-dropdown {
        display: none;
        border-top: 1px solid var(--border);
        animation: slideDown 0.25s ease;
    }

    .client-card.expanded .client-dropdown { display: block; }

    @keyframes slideDown {
        from { opacity: 0; transform: translateY(-8px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    /* Tab bar inside dropdown */
    .dropdown-tabs {
        display: flex;
        gap: 0;
        background: var(--surface2);
        border-bottom: 1px solid var(--border);
    }

    .dropdown-tab {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.75rem 1.4rem;
        font-family: 'Outfit', sans-serif;
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--text-muted);
        background: none;
        border: none;
        border-bottom: 2px solid transparent;
        cursor: pointer;
        transition: all 0.2s;
        margin-bottom: -1px;
    }

    .dropdown-tab:hover { color: var(--text); }

    .dropdown-tab.active { color: var(--accent); border-bottom-color: var(--accent); }

    .dt-count {
        background: rgba(255,255,255,0.08);
        color: var(--text-dim);
        font-size: 0.68rem;
        font-weight: 700;
        padding: 1px 6px;
        border-radius: 10px;
        min-width: 18px;
        text-align: center;
    }

    .dropdown-tab.active .dt-count { background: rgba(0,212,255,0.18); color: var(--accent); }

    /* Tab panels */
    .dropdown-panel {
        display: none;
        padding: 1.2rem 1.4rem;
        animation: fadeIn 0.2s ease;
    }

    .dropdown-panel.active { display: block; }

    /* ---- Service/Project entries ---- */
    .entry-list { display: flex; flex-direction: column; gap: 0.6rem; }

    .entry-item {
        display: grid;
        grid-template-columns: 36px 1fr auto auto;
        align-items: center;
        gap: 0.9rem;
        background: var(--surface2);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 0.85rem 1rem;
        transition: all 0.2s;
    }

    .entry-item:hover { border-color: var(--border2); background: var(--surface3); }

    .entry-icon {
        width: 36px; height: 36px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        flex-shrink: 0;
    }

    .ei-pending  { background: var(--warning-bg); }
    .ei-ongoing  { background: var(--info-bg); }
    .ei-done     { background: var(--success-bg); }

    .entry-body { min-width: 0; }

    .entry-title {
        font-weight: 600;
        font-size: 0.88rem;
        color: var(--white);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .entry-sub {
        font-size: 0.75rem;
        color: var(--text-muted);
        margin-top: 0.15rem;
    }

    .entry-date {
        font-family: 'DM Mono', monospace;
        font-size: 0.72rem;
        color: var(--text-muted);
        white-space: nowrap;
    }

    .entry-status {
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        padding: 0.25rem 0.7rem;
        border-radius: 8px;
        font-size: 0.72rem;
        font-weight: 700;
        white-space: nowrap;
    }

    .es-pending  { background: var(--warning-bg); color: var(--warning); }
    .es-ongoing  { background: var(--info-bg);    color: var(--info); }
    .es-done     { background: var(--success-bg); color: var(--success); }
    .es-review   { background: rgba(139,92,246,0.15); color: #A78BFA; }

    /* Progress bar inside project entry */
    .entry-progress { margin-top: 0.5rem; }

    .ep-bar {
        height: 4px;
        background: rgba(255,255,255,0.07);
        border-radius: 99px;
        overflow: hidden;
        margin-bottom: 0.25rem;
    }

    .ep-fill {
        height: 100%;
        border-radius: 99px;
        background: linear-gradient(90deg, var(--primary), var(--accent));
        transition: width 0.5s ease;
    }

    .ep-label {
        font-size: 0.72rem;
        color: var(--text-muted);
        display: flex;
        justify-content: space-between;
    }

    .empty-state {
        text-align: center;
        padding: 2rem;
        color: var(--text-muted);
        font-size: 0.88rem;
    }

    .empty-state .empty-icon { font-size: 2rem; margin-bottom: 0.5rem; opacity: 0.5; }

    /* Client detail sub-section */
    .client-detail-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 0.8rem;
    }

    .client-contact-strip {
        display: flex;
        gap: 1.5rem;
        padding: 0.9rem 1.4rem;
        background: var(--surface2);
        border-bottom: 1px solid var(--border);
        flex-wrap: wrap;
        align-items: center;
    }

    .contact-chip {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        font-size: 0.8rem;
        color: var(--text-dim);
    }

    .contact-chip .cc-icon { font-size: 0.85rem; }

    /* ===================== BUTTONS ===================== */
    .btn {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        padding: 0.62rem 1.2rem;
        border-radius: 10px;
        font-family: 'Outfit', sans-serif;
        font-size: 0.85rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        border: none;
        text-decoration: none;
    }

    .btn-primary {
        background: var(--primary);
        color: #fff;
        box-shadow: 0 4px 14px var(--primary-glow);
    }

    .btn-primary:hover { background: #1a5fff; transform: translateY(-1px); box-shadow: 0 6px 20px var(--primary-glow); }

    .btn-ghost {
        background: rgba(255,255,255,0.06);
        color: var(--text-dim);
        border: 1px solid var(--border2);
    }

    .btn-ghost:hover { background: rgba(255,255,255,0.1); color: var(--text); }

    .btn-sm { padding: 0.4rem 0.85rem; font-size: 0.78rem; border-radius: 8px; }

    .btn-danger { background: var(--danger-bg); color: var(--danger); border: 1px solid rgba(239,68,68,0.25); }
    .btn-danger:hover { background: rgba(239,68,68,0.2); }

    .btn-success { background: var(--success-bg); color: var(--success); border: 1px solid rgba(16,185,129,0.25); }
    .btn-success:hover { background: rgba(16,185,129,0.2); }

    /* ===================== SECTION DIVIDER ===================== */
    .section-divider {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin: 1.5rem 0 1rem;
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: var(--text-muted);
    }

    .section-divider::after { content: ''; flex: 1; height: 1px; background: var(--border); }

    /* ===================== NOTIFICATIONS PANEL ===================== */
    .notif-list { display: flex; flex-direction: column; gap: 0.6rem; }

    .notif-item {
        display: flex;
        align-items: flex-start;
        gap: 0.85rem;
        background: var(--surface2);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 0.9rem 1rem;
        border-left: 3px solid transparent;
    }

    .notif-item.ni-new     { border-left-color: var(--accent); }
    .notif-item.ni-warning { border-left-color: var(--warning); }
    .notif-item.ni-success { border-left-color: var(--success); }

    .notif-icon { font-size: 1.2rem; margin-top: 0.1rem; }
    .notif-body { flex: 1; min-width: 0; }
    .notif-title { font-size: 0.88rem; font-weight: 600; color: var(--text); }
    .notif-sub   { font-size: 0.78rem; color: var(--text-muted); margin-top: 0.18rem; }
    .notif-time  { font-family: 'DM Mono', monospace; font-size: 0.72rem; color: var(--text-muted); white-space: nowrap; }

    /* ===================== LOGOUT BUTTON ===================== */
    .btn-logout {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.42rem 0.9rem;
        border-radius: 8px;
        font-family: 'Outfit', sans-serif;
        font-size: 0.82rem;
        font-weight: 600;
        cursor: pointer;
        border: 1px solid rgba(239,68,68,0.3);
        background: rgba(239,68,68,0.08);
        color: var(--danger);
        transition: all 0.2s;
        text-decoration: none;
    }
    .btn-logout:hover { background: rgba(239,68,68,0.18); border-color: var(--danger); }

    /* ===================== DETAIL MODAL ===================== */
    .modal-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.65);
        backdrop-filter: blur(4px);
        z-index: 1000;
        align-items: center;
        justify-content: center;
        animation: fadeIn 0.2s ease;
    }
    .modal-overlay.open { display: flex; }

    .modal-box {
        background: var(--surface);
        border: 1px solid var(--border2);
        border-radius: 20px;
        width: 100%;
        max-width: 540px;
        margin: 1rem;
        box-shadow: 0 24px 60px rgba(0,0,0,0.5);
        animation: fadeInUp 0.25s ease;
        overflow: hidden;
    }

    .modal-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1.3rem 1.5rem 1rem;
        border-bottom: 1px solid var(--border);
    }

    .modal-title {
        font-family: 'Barlow', sans-serif;
        font-size: 1.25rem;
        font-weight: 800;
        color: var(--white);
        letter-spacing: -0.3px;
    }

    .modal-subtitle {
        font-size: 0.78rem;
        color: var(--text-muted);
        margin-top: 0.15rem;
    }

    .modal-close {
        width: 32px; height: 32px;
        border-radius: 8px;
        border: 1px solid var(--border2);
        background: rgba(255,255,255,0.05);
        color: var(--text-muted);
        cursor: pointer;
        font-size: 1.1rem;
        display: flex; align-items: center; justify-content: center;
        transition: all 0.2s;
        flex-shrink: 0;
    }
    .modal-close:hover { background: var(--danger-bg); color: var(--danger); border-color: rgba(239,68,68,0.3); }

    .modal-body { padding: 1.3rem 1.5rem; }

    .modal-img-placeholder {
        width: 100%;
        height: 180px;
        background: var(--surface2);
        border: 2px dashed var(--border2);
        border-radius: 14px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        color: var(--text-muted);
        font-size: 0.85rem;
        margin-bottom: 1.2rem;
    }
    .modal-img-placeholder .img-icon { font-size: 2.2rem; opacity: 0.4; }
    .modal-img-placeholder span { font-size: 0.78rem; opacity: 0.6; }

    .modal-detail-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.75rem;
        margin-bottom: 1rem;
    }

    .modal-detail-item { display: flex; flex-direction: column; gap: 0.2rem; }
    .modal-detail-label { font-size: 0.68rem; font-weight: 700; letter-spacing: 0.8px; text-transform: uppercase; color: var(--text-muted); }
    .modal-detail-value { font-size: 0.9rem; font-weight: 600; color: var(--white); }

    .modal-footer {
        display: flex;
        justify-content: flex-end;
        gap: 0.6rem;
        padding: 1rem 1.5rem 1.3rem;
        border-top: 1px solid var(--border);
    }

    /* ===================== LOGOUT CONFIRM MODAL ===================== */
    .logout-modal-box {
        background: var(--surface);
        border: 1px solid var(--border2);
        border-radius: 20px;
        width: 100%;
        max-width: 380px;
        margin: 1rem;
        box-shadow: 0 24px 60px rgba(0,0,0,0.5);
        animation: fadeInUp 0.25s ease;
        padding: 2rem 1.8rem 1.5rem;
        text-align: center;
    }
    .logout-modal-icon { font-size: 2.5rem; margin-bottom: 0.75rem; }
    .logout-modal-title { font-family:'Barlow',sans-serif; font-size:1.3rem; font-weight:800; color:var(--white); margin-bottom:0.4rem; }
    .logout-modal-sub { font-size:0.85rem; color:var(--text-muted); margin-bottom:1.5rem; }
    .logout-modal-actions { display:flex; gap:0.6rem; justify-content:center; }

    /* ===================== ANIMATIONS ===================== */
    @keyframes fadeIn    { from { opacity: 0; }  to { opacity: 1; } }
    @keyframes fadeInUp  { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }
    @keyframes fadeOut   { from { opacity: 1; transform: translateY(0); } to { opacity: 0; transform: translateY(-8px); } }

    /* ===================== RESPONSIVE ===================== */
    @media (max-width: 1100px) {
        .stats-row { grid-template-columns: repeat(2, 1fr); }
    }

    @media (max-width: 860px) {
        .admin-layout { grid-template-columns: 1fr; }
        .sidebar { display: none; }
        .client-row { grid-template-columns: 40px 1fr auto auto; }
        .client-date { display: none; }
    }

    @media (max-width: 600px) {
        .main-content { padding: 1.2rem; }
        .stats-row { grid-template-columns: 1fr 1fr; }
        .page-header h1 { font-size: 1.5rem; }
        .topbar { padding: 0 1.2rem; }
        .client-row { grid-template-columns: 40px 1fr auto; }
        .client-tag { display: none; }
    }
    /* ===================== DSS MODULES ===================== */
    .dss-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.2rem; margin-bottom: 2rem; }
    .dss-card { background: var(--surface); border: 1px solid var(--border); border-radius: 14px; padding: 1.4rem; transition: border-color 0.2s; }
    .dss-card:hover { border-color: var(--border2); }
    .dss-card-title { font-size: 0.72rem; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; color: var(--text-muted); margin-bottom: 0.6rem; }
    .dss-card-value { font-family: 'Barlow', sans-serif; font-size: 2rem; font-weight: 800; color: var(--white); margin-bottom: 0.2rem; }
    .dss-card-sub { font-size: 0.78rem; color: var(--text-muted); }
    .dss-card-icon { float: right; font-size: 1.8rem; opacity: 0.2; margin-top: -2.4rem; }

    /* Table */
    .data-table-wrap { background: var(--surface); border: 1px solid var(--border); border-radius: 14px; overflow: hidden; margin-bottom: 1.5rem; }
    .data-table-header { display: flex; align-items: center; justify-content: space-between; padding: 1rem 1.4rem; border-bottom: 1px solid var(--border); }
    .data-table-header h3 { font-size: 0.95rem; font-weight: 700; color: var(--white); }
    table { width: 100%; border-collapse: collapse; }
    thead th { padding: 0.75rem 1.2rem; text-align: left; font-size: 0.72rem; font-weight: 700; letter-spacing: 0.8px; text-transform: uppercase; color: var(--text-muted); background: var(--surface2); border-bottom: 1px solid var(--border); }
    tbody td { padding: 0.85rem 1.2rem; font-size: 0.87rem; color: var(--text); border-bottom: 1px solid var(--border); }
    tbody tr:last-child td { border-bottom: none; }
    tbody tr:hover td { background: rgba(255,255,255,0.02); }

    /* Status badges */
    .badge { display: inline-flex; align-items: center; gap: 0.3rem; padding: 0.25rem 0.65rem; border-radius: 8px; font-size: 0.72rem; font-weight: 700; }
    .badge-green  { background: var(--success-bg); color: var(--success); }
    .badge-yellow { background: var(--warning-bg); color: var(--warning); }
    .badge-red    { background: var(--danger-bg);  color: var(--danger); }
    .badge-blue   { background: var(--info-bg);    color: var(--info); }
    .badge-gray   { background: rgba(255,255,255,0.07); color: var(--text-muted); }

    /* Avatar cell */
    .emp-avatar { width: 34px; height: 34px; border-radius: 10px; display: inline-flex; align-items: center; justify-content: center; font-family: 'Barlow', sans-serif; font-weight: 800; font-size: 0.78rem; color: #fff; }

    /* Progress mini bar */
    .mini-bar { height: 6px; background: rgba(255,255,255,0.07); border-radius: 99px; overflow: hidden; min-width: 80px; }
    .mini-fill { height: 100%; border-radius: 99px; background: linear-gradient(90deg, var(--primary), var(--accent)); }

    /* Attendance calendar */
    .att-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 4px; margin-top: 1rem; }
    .att-day-label { font-size: 0.65rem; font-weight: 700; text-align: center; color: var(--text-muted); padding-bottom: 4px; text-transform: uppercase; }
    .att-cell { aspect-ratio: 1; border-radius: 6px; display: flex; align-items: center; justify-content: center; font-size: 0.72rem; font-weight: 600; cursor: default; transition: transform 0.15s; }
    .att-cell:hover { transform: scale(1.15); }
    .att-present  { background: var(--success-bg); color: var(--success); }
    .att-absent   { background: var(--danger-bg);  color: var(--danger); }
    .att-late     { background: var(--warning-bg); color: var(--warning); }
    .att-off      { background: rgba(255,255,255,0.04); color: var(--text-muted); }
    .att-empty    { background: transparent; }

    /* Chart bars */
    .bar-chart { display: flex; align-items: flex-end; gap: 0.5rem; height: 120px; margin-top: 1rem; }
    .bar-col { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 0.3rem; }
    .bar-body { width: 100%; border-radius: 6px 6px 0 0; background: linear-gradient(180deg, var(--accent), var(--primary)); transition: height 0.5s ease; }
    .bar-label { font-size: 0.65rem; color: var(--text-muted); font-weight: 600; }

    /* Upload dropzone */
    .upload-zone { border: 2px dashed var(--border2); border-radius: 14px; padding: 2.5rem; text-align: center; cursor: pointer; transition: all 0.25s; }
    .upload-zone:hover { border-color: var(--accent); background: rgba(0,212,255,0.04); }
    .upload-zone-icon { font-size: 2.5rem; margin-bottom: 0.5rem; }
    .upload-zone p { color: var(--text-muted); font-size: 0.88rem; }
    .upload-zone strong { color: var(--accent); }

    /* File list */
    .file-list { display: flex; flex-direction: column; gap: 0.6rem; }
    .file-item { display: flex; align-items: center; gap: 1rem; background: var(--surface2); border: 1px solid var(--border); border-radius: 12px; padding: 0.9rem 1.1rem; transition: border-color 0.2s; }
    .file-item:hover { border-color: var(--border2); }
    .file-icon { font-size: 1.6rem; flex-shrink: 0; }
    .file-info { flex: 1; min-width: 0; }
    .file-name { font-size: 0.88rem; font-weight: 600; color: var(--white); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .file-meta { font-size: 0.75rem; color: var(--text-muted); margin-top: 0.15rem; }

    /* Payroll row highlight */
    .pay-highlight td:first-child { border-left: 3px solid var(--accent); }

    /* KPI insight card */
    .insight-card { background: var(--surface2); border: 1px solid var(--border); border-radius: 12px; padding: 1.1rem 1.3rem; display: flex; align-items: flex-start; gap: 0.8rem; }
    .insight-icon { font-size: 1.4rem; flex-shrink: 0; }
    .insight-title { font-size: 0.85rem; font-weight: 700; color: var(--white); margin-bottom: 0.2rem; }
    .insight-desc { font-size: 0.78rem; color: var(--text-muted); line-height: 1.5; }
    .insights-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 0.75rem; margin-bottom: 2rem; }
    </style>
</head>
