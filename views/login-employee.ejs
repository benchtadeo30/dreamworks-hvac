<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Technician Login — DreamWorks HVAC</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Barlow:wght@400;600;700;800&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

        :root {
            --primary:        #0038FF;
            --primary-dark:   #0028CC;
            --secondary:      #00D4FF;
            --dark:           #0A0F1C;
            --gray:           #64748B;
            --light-gray:     #E2E8F0;
            --white:          #FFFFFF;
            --success:        #10B981;
            --error:          #EF4444;
            --tech-green:     #22C55E;
            --tech-green-dark:#16A34A;
            --tech-teal:      #06B6D4;
        }

        body {
            font-family: 'Outfit', sans-serif;
            background: linear-gradient(155deg, #071A10 0%, #0A1F1A 45%, #061530 100%);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 2rem;
            position: relative;
            overflow-x: hidden;
        }

        /* Background glows */
        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background:
                radial-gradient(ellipse 65% 50% at 10% 25%, rgba(34,197,94,0.18) 0%, transparent 60%),
                radial-gradient(ellipse 55% 40% at 88% 70%, rgba(6,182,212,0.14) 0%, transparent 60%),
                radial-gradient(ellipse 35% 30% at 50% 90%, rgba(0,56,255,0.1) 0%, transparent 60%);
            pointer-events: none;
        }

        /* Diagonal stripe texture */
        body::after {
            content: '';
            position: fixed;
            inset: 0;
            background-image: repeating-linear-gradient(
                -45deg,
                rgba(34,197,94,0.025) 0px,
                rgba(34,197,94,0.025) 1px,
                transparent 1px,
                transparent 28px
            );
            pointer-events: none;
        }

        /* Floating orbs */
        .orb {
            position: fixed;
            border-radius: 50%;
            filter: blur(70px);
            opacity: 0.15;
            animation: orbDrift linear infinite;
            pointer-events: none;
        }
        .orb-1 { width: 320px; height: 320px; background: var(--tech-green); top: -80px; right: -60px; animation-duration: 28s; }
        .orb-2 { width: 220px; height: 220px; background: var(--tech-teal);  bottom: -60px; left: 5%;  animation-duration: 22s; animation-delay: -8s; }
        .orb-3 { width: 160px; height: 160px; background: var(--primary);    top: 50%;  left: -40px;  animation-duration: 18s; animation-delay: -4s; }

        @keyframes orbDrift {
            0%   { transform: translate(0,0) scale(1); }
            33%  { transform: translate(-30px, 25px) scale(1.08); }
            66%  { transform: translate(20px, -20px) scale(0.93); }
            100% { transform: translate(0,0) scale(1); }
        }

        /* ── Top Nav ── */
        .page-nav {
            position: fixed;
            top: 0; left: 0; right: 0;
            z-index: 100;
            padding: 1.1rem 2rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: rgba(0,0,0,0.3);
            backdrop-filter: blur(16px);
            border-bottom: 1px solid rgba(255,255,255,0.06);
        }

        .brand-logo {
            font-family: 'Barlow', sans-serif;
            font-size: 1.5rem;
            font-weight: 800;
            color: #fff;
            text-decoration: none;
            letter-spacing: -0.5px;
        }
        .brand-logo span { color: var(--secondary); }

        .nav-right {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .tech-badge-nav {
            display: flex;
            align-items: center;
            gap: 0.4rem;
            background: rgba(34,197,94,0.12);
            border: 1px solid rgba(34,197,94,0.28);
            color: var(--tech-green);
            padding: 0.3rem 0.85rem;
            border-radius: 50px;
            font-size: 0.73rem;
            font-weight: 700;
            letter-spacing: 0.6px;
            text-transform: uppercase;
        }

        .nav-back {
            display: flex;
            align-items: center;
            gap: 0.45rem;
            color: rgba(255,255,255,0.5);
            text-decoration: none;
            font-size: 0.85rem;
            font-weight: 500;
            transition: color 0.2s;
        }
        .nav-back:hover { color: rgba(255,255,255,0.85); }

        /* ── Main wrapper ── */
        .login-wrapper {
            width: 100%;
            max-width: 480px;
            position: relative;
            z-index: 2;
            animation: slideUp 0.75s cubic-bezier(0.22, 1, 0.36, 1) both;
            margin-top: 5rem;
        }

        @keyframes slideUp {
            from { opacity: 0; transform: translateY(50px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        /* ── Header ── */
        .login-eyebrow {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            background: rgba(34,197,94,0.1);
            border: 1px solid rgba(34,197,94,0.22);
            color: var(--tech-green);
            padding: 0.38rem 1rem;
            border-radius: 50px;
            font-size: 0.77rem;
            font-weight: 700;
            letter-spacing: 0.9px;
            text-transform: uppercase;
            margin-bottom: 1.2rem;
        }

        .login-heading {
            font-family: 'Barlow', sans-serif;
            font-size: 3rem;
            font-weight: 800;
            color: #fff;
            line-height: 1.0;
            letter-spacing: -1.5px;
            margin-bottom: 0.5rem;
        }
        .login-heading .accent-green { color: var(--tech-green); }
        .login-heading .accent-teal  { color: var(--tech-teal); }

        .login-subheading {
            color: rgba(255,255,255,0.45);
            font-size: 0.93rem;
            margin-bottom: 2rem;
        }

        /* ── Card ── */
        .login-card {
            background: rgba(255,255,255,0.04);
            backdrop-filter: blur(24px);
            border-radius: 24px;
            padding: 2.2rem;
            border: 1px solid rgba(255,255,255,0.09);
            box-shadow:
                0 30px 80px rgba(0,0,0,0.55),
                0 0 0 1px rgba(34,197,94,0.05),
                inset 0 1px 0 rgba(255,255,255,0.07);
            position: relative;
            overflow: hidden;
        }

        /* Green top accent line */
        .login-card::before {
            content: '';
            position: absolute;
            top: 0; left: 10%; right: 10%;
            height: 2px;
            background: linear-gradient(90deg, transparent, var(--tech-green), transparent);
            border-radius: 0 0 2px 2px;
        }

        /* ── Status bar ── */
        .status-bar {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.7rem 1rem;
            background: rgba(34,197,94,0.07);
            border: 1px solid rgba(34,197,94,0.14);
            border-radius: 10px;
            margin-bottom: 1.6rem;
        }

        .status-icon {
            font-size: 1rem;
            width: 30px; height: 30px;
            background: rgba(34,197,94,0.14);
            border-radius: 8px;
            display: flex; align-items: center; justify-content: center;
            flex-shrink: 0;
        }

        .status-text { flex: 1; }

        .status-title {
            font-size: 0.78rem;
            font-weight: 700;
            color: var(--tech-green);
            letter-spacing: 0.4px;
            text-transform: uppercase;
        }

        .status-sub {
            font-size: 0.72rem;
            color: rgba(255,255,255,0.35);
        }

        .online-dot {
            width: 8px; height: 8px;
            border-radius: 50%;
            background: var(--tech-green);
            box-shadow: 0 0 0 3px rgba(34,197,94,0.2);
            animation: blink 2s ease-in-out infinite;
            flex-shrink: 0;
        }

        @keyframes blink {
            0%, 100% { opacity: 1; box-shadow: 0 0 0 3px rgba(34,197,94,0.2); }
            50%       { opacity: 0.6; box-shadow: 0 0 0 6px rgba(34,197,94,0.08); }
        }

        /* ── Error ── */
        .error-msg {
            background: rgba(239,68,68,0.1);
            border: 1px solid rgba(239,68,68,0.28);
            color: #FCA5A5;
            padding: 0.75rem 1rem;
            border-radius: 10px;
            font-size: 0.85rem;
            margin-bottom: 1rem;
            display: none;
        }
        .error-msg.show { display: block; animation: shakeX 0.4s ease; }

        @keyframes shakeX {
            0%, 100% { transform: translateX(0); }
            25%       { transform: translateX(-6px); }
            75%       { transform: translateX(6px); }
        }

        /* ── Form ── */
        .form-group { margin-bottom: 1.1rem; }

        .form-group label {
            display: block;
            font-size: 0.82rem;
            font-weight: 600;
            color: rgba(255,255,255,0.6);
            margin-bottom: 0.45rem;
            letter-spacing: 0.3px;
        }

        .input-wrap {
            position: relative;
            display: flex;
            align-items: center;
        }

        .input-icon {
            position: absolute;
            left: 0.9rem;
            font-size: 1rem;
            pointer-events: none;
            z-index: 1;
            opacity: 0.65;
        }

        .input-wrap input {
            width: 100%;
            padding: 0.85rem 1rem 0.85rem 2.6rem;
            background: rgba(255,255,255,0.06);
            border: 1.5px solid rgba(255,255,255,0.09);
            border-radius: 12px;
            color: #fff;
            font-family: 'Outfit', sans-serif;
            font-size: 0.95rem;
            transition: all 0.25s;
            outline: none;
        }

        .input-wrap input::placeholder { color: rgba(255,255,255,0.28); }

        .input-wrap input:focus {
            border-color: var(--tech-green);
            background: rgba(34,197,94,0.06);
            box-shadow: 0 0 0 3px rgba(34,197,94,0.1);
        }

        .password-toggle {
            position: absolute;
            right: 0.9rem;
            background: none;
            border: none;
            cursor: pointer;
            font-size: 0.95rem;
            opacity: 0.45;
            padding: 0.2rem;
            transition: opacity 0.2s;
        }
        .password-toggle:hover { opacity: 1; }

        /* Employee ID field hint */
        .input-hint {
            font-size: 0.72rem;
            color: rgba(255,255,255,0.3);
            margin-top: 0.3rem;
        }

        .form-row-between {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 1.4rem;
        }

        .remember-label {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-size: 0.83rem;
            color: rgba(255,255,255,0.45);
            cursor: pointer;
        }

        .remember-label input[type="checkbox"] {
            accent-color: var(--tech-green);
            width: 14px; height: 14px;
        }

        .forgot-link {
            font-size: 0.83rem;
            color: rgba(255,255,255,0.38);
            text-decoration: none;
            transition: color 0.2s;
        }
        .forgot-link:hover { color: var(--tech-green); }

        /* ── Submit ── */
        .btn-submit {
            width: 100%;
            padding: 0.95rem;
            background: linear-gradient(135deg, var(--tech-green) 0%, var(--tech-green-dark) 100%);
            color: #fff;
            border: none;
            border-radius: 12px;
            font-family: 'Outfit', sans-serif;
            font-size: 1rem;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.28s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            box-shadow: 0 6px 24px rgba(34,197,94,0.3);
            letter-spacing: 0.2px;
        }

        .btn-submit:hover:not(:disabled) {
            transform: translateY(-2px);
            box-shadow: 0 10px 32px rgba(34,197,94,0.45);
        }

        .btn-submit:disabled { opacity: 0.65; cursor: not-allowed; transform: none; }

        .spinner {
            width: 18px; height: 18px;
            border: 2.5px solid rgba(255,255,255,0.3);
            border-top-color: #fff;
            border-radius: 50%;
            animation: spin 0.7s linear infinite;
        }
        @keyframes spin { to { transform: rotate(360deg); } }

        /* ── Quick login chips ── */
        .quick-login-row {
            display: flex;
            gap: 0.5rem;
            margin-bottom: 1.5rem;
            flex-wrap: wrap;
        }

        .quick-chip {
            display: flex;
            align-items: center;
            gap: 0.35rem;
            padding: 0.42rem 0.85rem;
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 50px;
            color: rgba(255,255,255,0.55);
            font-size: 0.78rem;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s;
        }

        .quick-chip:hover {
            background: rgba(34,197,94,0.1);
            border-color: rgba(34,197,94,0.3);
            color: var(--tech-green);
        }

        .chip-divider {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            margin: 0 0 1.4rem;
            color: rgba(255,255,255,0.2);
            font-size: 0.78rem;
        }
        .chip-divider::before,
        .chip-divider::after { content: ''; flex: 1; height: 1px; background: rgba(255,255,255,0.08); }

        /* ── Divider + footer ── */
        .card-divider {
            height: 1px;
            background: rgba(255,255,255,0.07);
            margin: 1.4rem 0;
        }

        .card-footer {
            text-align: center;
            font-size: 0.78rem;
            color: rgba(255,255,255,0.28);
            line-height: 1.9;
        }

        .card-footer a {
            color: rgba(255,255,255,0.45);
            text-decoration: none;
            transition: color 0.2s;
        }
        .card-footer a:hover { color: var(--tech-green); }

        /* ── Success ── */
        .success-panel {
            display: none;
            text-align: center;
            padding: 1rem 0;
            animation: fadeIn 0.5s ease;
        }
        .success-panel.show { display: block; }

        .success-icon-wrap {
            width: 84px; height: 84px;
            background: linear-gradient(135deg, var(--tech-green), var(--tech-green-dark));
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            margin: 0 auto 1.5rem;
            font-size: 2.2rem;
            box-shadow: 0 14px 44px rgba(34,197,94,0.4);
            animation: popIn 0.5s cubic-bezier(0.34,1.56,0.64,1);
        }

        @keyframes popIn  { from { transform: scale(0); } to { transform: scale(1); } }
        @keyframes fadeIn { from { opacity: 0; }         to { opacity: 1; } }

        .success-panel h3 {
            font-family: 'Barlow', sans-serif;
            font-size: 1.75rem;
            font-weight: 800;
            color: #fff;
            margin-bottom: 0.4rem;
            letter-spacing: -0.5px;
        }

        .success-panel .shift-info {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            background: rgba(34,197,94,0.1);
            border: 1px solid rgba(34,197,94,0.22);
            color: var(--tech-green);
            padding: 0.35rem 1rem;
            border-radius: 50px;
            font-size: 0.8rem;
            font-weight: 600;
            margin: 0.5rem 0 1.5rem;
        }

        .success-panel p {
            color: rgba(255,255,255,0.45);
            font-size: 0.9rem;
            margin-bottom: 1.5rem;
        }

        .btn-portal {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.9rem 2.2rem;
            background: linear-gradient(135deg, var(--tech-green), var(--tech-green-dark));
            color: #fff;
            border-radius: 50px;
            font-weight: 700;
            font-size: 0.95rem;
            text-decoration: none;
            box-shadow: 0 6px 24px rgba(34,197,94,0.35);
            transition: all 0.3s;
        }
        .btn-portal:hover {
            transform: translateY(-2px);
            box-shadow: 0 12px 36px rgba(34,197,94,0.5);
        }

        /* ── Today's shift preview ── */
        .shift-preview {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.8rem 1rem;
            background: rgba(6,182,212,0.07);
            border: 1px solid rgba(6,182,212,0.14);
            border-radius: 10px;
            margin-top: 1rem;
        }

        .shift-icon {
            font-size: 1.2rem;
            flex-shrink: 0;
        }

        .shift-text { flex: 1; }

        .shift-title {
            font-size: 0.78rem;
            font-weight: 700;
            color: var(--tech-teal);
            text-transform: uppercase;
            letter-spacing: 0.4px;
        }

        .shift-detail {
            font-size: 0.75rem;
            color: rgba(255,255,255,0.38);
        }

        @media (max-width: 520px) {
            body { padding: 1rem; }
            .login-card { padding: 1.6rem; }
            .login-heading { font-size: 2.4rem; }
            .quick-login-row { display: none; }
        }
    </style>
</head>
<body>

    <!-- BG Orbs -->
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>

    <!-- Nav -->
    <nav class="page-nav">
        <a href="/" class="brand-logo">DREAM<span>WORKS</span></a>
        <div class="nav-right">
            <div class="tech-badge-nav">👷 Technician Portal</div>
            <a href="/" class="nav-back">
                <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
                Back
            </a>
        </div>
    </nav>

    <!-- Main -->
    <div class="login-wrapper">
        <div class="login-eyebrow">👷 Field Technician Access</div>
        <h1 class="login-heading">Tech<br><span class="accent-green">Portal</span> <span class="accent-teal">Login</span></h1>
        <p class="login-subheading">Clock in, view your jobs, and manage your daily tasks.</p>

        <div class="login-card">

            <!-- Login Form -->
            <div id="loginSection">

                <!-- Status bar -->
                <div class="status-bar">
                    <div class="status-icon">📡</div>
                    <div class="status-text">
                        <div class="status-title">System Online</div>
                        <div class="status-sub">Dispatch active · <span id="liveTime"></span></div>
                    </div>
                    <div class="online-dot"></div>
                </div>

                <!-- Quick login chips -->
                <div class="quick-login-row">
                    <div class="quick-chip" onclick="fillDemo()">⚡ Demo Login</div>
                    <div class="quick-chip" onclick="fillQR()">📱 Use QR Badge</div>
                </div>
                <div class="chip-divider">or sign in manually</div>

                <div class="error-msg" id="errorMsg">⚠️ Invalid Employee ID or password.</div>

                <div class="form-group">
                    <label>Employee ID</label>
                    <div class="input-wrap">
                        <span class="input-icon">🪪</span>
                        <input type="text" id="empId" placeholder="e.g. DW-TECH-001" autocomplete="username">
                    </div>
                    <div class="input-hint">Your ID is on your company badge or welcome email.</div>
                </div>

                <div class="form-group">
                    <label>Password</label>
                    <div class="input-wrap">
                        <span class="input-icon">🔒</span>
                        <input type="password" id="empPassword" placeholder="Enter your password" autocomplete="current-password">
                        <button class="password-toggle" type="button" onclick="togglePw('empPassword', this)">👁️</button>
                    </div>
                </div>

                <div class="form-row-between">
                    <label class="remember-label">
                        <input type="checkbox" id="rememberMe"> Keep me signed in
                    </label>
                    <a href="#" class="forgot-link">Forgot password?</a>
                </div>

                <button class="btn-submit" id="submitBtn" onclick="handleLogin()">
                    👷 &nbsp;Clock In & Enter Portal
                </button>

                <!-- Today's shift preview -->
                <div class="shift-preview">
                    <div class="shift-icon">📋</div>
                    <div class="shift-text">
                        <div class="shift-title">Today's Schedule</div>
                        <div class="shift-detail">Sign in to view your assigned jobs & routes</div>
                    </div>
                </div>

                <div class="card-divider"></div>

                <div class="card-footer">
                    Not a technician? &nbsp;
                    <a href="/admin/login">Admin login</a>
                    &nbsp;·&nbsp;
                    <a href="/customer/login">Customer login</a>
                    <br>
                    <a href="/">← Return to main site</a>
                </div>
            </div>

            <!-- Success Panel -->
            <div class="success-panel" id="successPanel">
                <div class="success-icon-wrap">✓</div>
                <h3>Clocked In!</h3>
                <div class="shift-info" id="shiftBadge">🟢 Shift Started — <span id="clockInTime"></span></div>
                <p>Welcome back, Technician. Loading your jobs and schedule…</p>
                <a href="/employee" class="btn-portal">🔧 &nbsp;Go to My Portal →</a>
            </div>

        </div>
    </div>

    <script>
        // ── Live clock ──
        function updateTime() {
            const now = new Date();
            document.getElementById('liveTime').textContent =
                now.toLocaleTimeString('en-PH', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
        }
        updateTime();
        setInterval(updateTime, 1000);

        // ── Password toggle ──
        function togglePw(id, btn) {
            const input = document.getElementById(id);
            if (input.type === 'password') { input.type = 'text'; btn.textContent = '🙈'; }
            else { input.type = 'password'; btn.textContent = '👁️'; }
        }

        // ── Demo fill ──
        function fillDemo() {
            document.getElementById('empId').value = 'DW-TECH-001';
            document.getElementById('empPassword').value = 'demo1234';
            document.getElementById('empId').dispatchEvent(new Event('input'));
        }

        // ── QR badge stub ──
        function fillQR() {
            const chip = event.currentTarget;
            chip.textContent = '📷 Camera opening…';
            setTimeout(() => {
                chip.textContent = '📱 Use QR Badge';
                showError('QR login coming soon!');
            }, 1500);
        }

        // ── Error helper ──
        function showError(msg) {
            const err = document.getElementById('errorMsg');
            err.textContent = '⚠️ ' + msg;
            err.classList.add('show');
            setTimeout(() => err.classList.remove('show'), 4500);
        }

        // ── Login handler ──
        function handleLogin() {
            const id   = document.getElementById('empId').value.trim();
            const pass = document.getElementById('empPassword').value;
            const btn  = document.getElementById('submitBtn');

            document.getElementById('errorMsg').classList.remove('show');

            if (!id)   { showError('Please enter your Employee ID.'); return; }
            if (!pass) { showError('Please enter your password.'); return; }

            btn.innerHTML = '<div class="spinner"></div> &nbsp;Verifying…';
            btn.disabled = true;

            setTimeout(() => {
                btn.innerHTML = '👷 &nbsp;Clock In & Enter Portal';
                btn.disabled = false;

                // Set clock-in time
                const now = new Date();
                document.getElementById('clockInTime').textContent =
                    now.toLocaleTimeString('en-PH', { hour: '2-digit', minute: '2-digit' });

                document.getElementById('loginSection').style.display = 'none';
                document.getElementById('successPanel').classList.add('show');
                setTimeout(() => { window.location.href = '/employee'; }, 2800);
            }, 1500);
        }

        // ── Enter key ──
        document.addEventListener('keydown', e => {
            if (e.key === 'Enter' && document.getElementById('loginSection').style.display !== 'none') {
                handleLogin();
            }
        });
    </script>
</body>
</html>
