<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Customer Login — DreamWorks HVAC</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Barlow:wght@400;600;700;800&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

        :root {
            --primary: #0038FF;
            --primary-dark: #0028CC;
            --secondary: #00D4FF;
            --dark: #0A0F1C;
            --gray: #64748B;
            --light-gray: #E2E8F0;
            --white: #FFFFFF;
            --success: #10B981;
            --error: #EF4444;
        }

        body {
            font-family: 'Outfit', sans-serif;
            background: linear-gradient(135deg, #0038FF 0%, #0028CC 50%, #1A1F35 100%);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 2rem;
            position: relative;
            overflow-x: hidden;
        }

        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background:
                radial-gradient(circle at 75% 20%, rgba(0,212,255,0.18) 0%, transparent 50%),
                radial-gradient(circle at 20% 80%, rgba(61,104,255,0.18) 0%, transparent 50%);
            pointer-events: none;
        }

        /* Floating particles */
        .particle {
            position: fixed;
            border-radius: 50%;
            background: rgba(0,212,255,0.12);
            animation: float linear infinite;
            pointer-events: none;
        }

        @keyframes float {
            0% { transform: translateY(100vh) scale(0); opacity: 0; }
            10% { opacity: 1; }
            90% { opacity: 1; }
            100% { transform: translateY(-100px) scale(1); opacity: 0; }
        }

        /* Nav */
        .page-nav {
            position: fixed;
            top: 0; left: 0; right: 0;
            z-index: 100;
            padding: 1.2rem 2rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: rgba(0,0,0,0.15);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(255,255,255,0.08);
        }

        .brand-logo {
            font-family: 'Barlow', sans-serif;
            font-size: 1.5rem;
            font-weight: 800;
            color: #fff;
            text-decoration: none;
            letter-spacing: -0.5px;
        }
        .brand-logo span { color: var(--secondary); }

        .nav-back {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            color: rgba(255,255,255,0.75);
            text-decoration: none;
            font-size: 0.88rem;
            font-weight: 500;
            transition: color 0.2s;
        }
        .nav-back:hover { color: #fff; }

        /* Wrapper */
        .login-wrapper {
            width: 100%;
            max-width: 460px;
            position: relative;
            z-index: 2;
            animation: slideUp 0.7s cubic-bezier(0.22, 1, 0.36, 1) both;
            margin-top: 4rem;
        }

        @keyframes slideUp {
            from { opacity: 0; transform: translateY(40px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Badge */
        .role-badge {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            background: rgba(255,255,255,0.12);
            border: 1px solid rgba(255,255,255,0.2);
            color: #fff;
            padding: 0.4rem 1rem;
            border-radius: 50px;
            font-size: 0.82rem;
            font-weight: 600;
            margin-bottom: 1.2rem;
            backdrop-filter: blur(10px);
        }

        .login-heading {
            font-family: 'Barlow', sans-serif;
            font-size: 2.8rem;
            font-weight: 800;
            color: #fff;
            line-height: 1.05;
            letter-spacing: -1.5px;
            margin-bottom: 0.5rem;
        }
        .login-heading span { color: var(--secondary); }

        .login-subheading {
            color: rgba(255,255,255,0.7);
            font-size: 0.97rem;
            margin-bottom: 2rem;
        }

        /* Card */
        .login-card {
            background: rgba(255,255,255,0.97);
            border-radius: 24px;
            padding: 2.2rem;
            box-shadow: 0 30px 80px rgba(0,0,0,0.35);
            border: 1px solid rgba(255,255,255,0.5);
        }

        /* Social */
        .social-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0.75rem;
            margin-bottom: 1.5rem;
        }

        .social-btn {
            padding: 0.78rem;
            border: 2px solid var(--light-gray);
            border-radius: 12px;
            background: #fff;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            font-family: 'Outfit', sans-serif;
            font-weight: 600;
            font-size: 0.88rem;
            color: var(--dark);
            transition: all 0.25s;
        }
        .social-btn:hover { border-color: var(--primary); background: #f0f4ff; transform: translateY(-1px); }

        .divider {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            margin: 1.4rem 0;
            color: var(--gray);
            font-size: 0.83rem;
        }
        .divider::before, .divider::after { content: ''; flex: 1; height: 1px; background: var(--light-gray); }

        /* Form */
        .form-group { margin-bottom: 1.1rem; }

        .form-group label {
            display: block;
            font-weight: 600;
            font-size: 0.87rem;
            color: var(--dark);
            margin-bottom: 0.4rem;
        }

        .input-wrap {
            position: relative;
        }

        .input-wrap input {
            width: 100%;
            padding: 0.85rem 1rem 0.85rem 2.8rem;
            border: 2px solid var(--light-gray);
            border-radius: 12px;
            font-family: 'Outfit', sans-serif;
            font-size: 0.95rem;
            transition: all 0.25s;
            background: #fff;
            color: var(--dark);
        }
        .input-wrap input:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(0,56,255,0.1);
        }
        .input-wrap input::placeholder { color: #a0aec0; }

        .input-icon {
            position: absolute;
            left: 0.9rem;
            top: 50%;
            transform: translateY(-50%);
            color: #94a3b8;
            font-size: 1rem;
            pointer-events: none;
        }

        .password-toggle {
            position: absolute;
            right: 0.9rem;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            cursor: pointer;
            color: #94a3b8;
            padding: 0;
            font-size: 1rem;
            transition: color 0.2s;
        }
        .password-toggle:hover { color: var(--primary); }

        .form-row-between {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 1.5rem;
        }

        .remember-label {
            display: flex;
            align-items: center;
            gap: 0.45rem;
            font-size: 0.87rem;
            color: var(--gray);
            cursor: pointer;
        }
        .remember-label input { width: 16px; height: 16px; cursor: pointer; accent-color: var(--primary); }

        .forgot-link {
            font-size: 0.87rem;
            color: var(--primary);
            text-decoration: none;
            font-weight: 600;
        }
        .forgot-link:hover { text-decoration: underline; }

        /* Error */
        .error-msg {
            background: #FEF2F2;
            border: 1px solid #FCA5A5;
            color: #B91C1C;
            border-radius: 10px;
            padding: 0.75rem 1rem;
            font-size: 0.87rem;
            margin-bottom: 1rem;
            display: none;
            animation: shake 0.4s ease;
        }
        .error-msg.show { display: block; }
        @keyframes shake {
            0%,100% { transform: translateX(0); }
            20%,60% { transform: translateX(-6px); }
            40%,80% { transform: translateX(6px); }
        }

        /* Submit */
        .btn-submit {
            width: 100%;
            padding: 1rem;
            background: linear-gradient(135deg, var(--primary), #3D68FF);
            color: #fff;
            border: none;
            border-radius: 14px;
            font-family: 'Outfit', sans-serif;
            font-size: 1rem;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s;
            box-shadow: 0 5px 20px rgba(0,56,255,0.35);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            letter-spacing: 0.2px;
        }
        .btn-submit:hover { transform: translateY(-2px); box-shadow: 0 10px 30px rgba(0,56,255,0.45); }
        .btn-submit:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }

        /* Footer */
        .card-footer {
            text-align: center;
            margin-top: 1.5rem;
            padding-top: 1.5rem;
            border-top: 1px solid var(--light-gray);
            font-size: 0.9rem;
            color: var(--gray);
        }
        .card-footer a { color: var(--primary); text-decoration: none; font-weight: 600; }
        .card-footer a:hover { text-decoration: underline; }

        /* Spinner */
        .spinner {
            width: 18px; height: 18px;
            border: 2.5px solid rgba(255,255,255,0.4);
            border-top-color: #fff;
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
        }
        @keyframes spin { to { transform: rotate(360deg); } }

        /* Success state */
        .success-panel {
            display: none;
            text-align: center;
            padding: 1rem 0;
            animation: fadeIn 0.5s ease;
        }
        .success-panel.show { display: block; }
        .success-icon-wrap {
            width: 80px; height: 80px;
            background: linear-gradient(135deg, var(--success), #059669);
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            margin: 0 auto 1.5rem;
            font-size: 2.2rem;
            animation: popIn 0.5s cubic-bezier(0.34,1.56,0.64,1);
        }
        @keyframes popIn { from { transform: scale(0); } to { transform: scale(1); } }
        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

        .success-panel h3 {
            font-family: 'Barlow', sans-serif;
            font-size: 1.6rem;
            font-weight: 800;
            color: var(--dark);
            margin-bottom: 0.5rem;
        }
        .success-panel p { color: var(--gray); font-size: 0.93rem; margin-bottom: 1.5rem; }

        .btn-portal {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.9rem 2rem;
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            color: #fff;
            border-radius: 50px;
            font-weight: 700;
            font-size: 0.95rem;
            text-decoration: none;
            box-shadow: 0 5px 20px rgba(0,56,255,0.3);
            transition: all 0.3s;
        }
        .btn-portal:hover { transform: translateY(-2px); box-shadow: 0 10px 30px rgba(0,56,255,0.45); }

        @media (max-width: 500px) {
            body { padding: 1rem; }
            .login-card { padding: 1.6rem; }
            .login-heading { font-size: 2.2rem; }
            .social-row { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>

    <!-- Particles -->
    <script>
        for (let i = 0; i < 8; i++) {
            const p = document.createElement('div');
            p.className = 'particle';
            const size = Math.random() * 60 + 20;
            p.style.cssText = `width:${size}px;height:${size}px;left:${Math.random()*100}%;animation-duration:${Math.random()*15+10}s;animation-delay:${Math.random()*10}s`;
            document.body.appendChild(p);
        }
    </script>

    <nav class="page-nav">
        <a href="/" class="brand-logo">DREAM<span>WORKS</span></a>
        <a href="/" class="nav-back">
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
            Back to Home
        </a>
    </nav>

    <div class="login-wrapper">
        <div class="role-badge">👤 Customer Portal</div>
        <h1 class="login-heading">Welcome<br><span>Back</span></h1>
        <p class="login-subheading">Sign in to track your projects and manage services</p>

        <div class="login-card">
            <div id="loginForm">
                <!-- Social -->
                <div class="social-row">
                    <button class="social-btn" onclick="handleSocial('Google')">
                        <svg width="18" height="18" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
                        Google
                    </button>
                    <button class="social-btn" onclick="handleSocial('Facebook')">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="#1877F2"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                        Facebook
                    </button>
                </div>

                <div class="divider">or sign in with email</div>

                <div class="error-msg" id="errorMsg">⚠️ Invalid email or password. Please try again.</div>

                <div class="form-group">
                    <label>Email Address</label>
                    <div class="input-wrap">
                        <span class="input-icon">✉️</span>
                        <input type="email" id="loginEmail" placeholder="juan@email.com" autocomplete="email">
                    </div>
                </div>

                <div class="form-group">
                    <label>Password</label>
                    <div class="input-wrap">
                        <span class="input-icon">🔒</span>
                        <input type="password" id="loginPassword" placeholder="Your password" autocomplete="current-password">
                        <button class="password-toggle" type="button" onclick="togglePw('loginPassword', this)">👁️</button>
                    </div>
                </div>

                <div class="form-row-between">
                    <label class="remember-label">
                        <input type="checkbox" id="rememberMe"> Remember me
                    </label>
                    <a href="#" class="forgot-link">Forgot password?</a>
                </div>

                <button class="btn-submit" id="submitBtn" onclick="handleLogin()">
                    Sign In →
                </button>

                <div class="card-footer">
                    Don't have an account? <a href="/registration">Create one free</a>
                    &nbsp;·&nbsp; <a href="/">← Back to site</a>
                </div>
            </div>

            <!-- Success -->
            <div class="success-panel" id="successPanel">
                <div class="success-icon-wrap">✓</div>
                <h3>Welcome back!</h3>
                <p>You're signed in. Redirecting you to your customer portal…</p>
                <a href="/customer" class="btn-portal">🏠 Go to My Portal →</a>
            </div>
        </div>
    </div>

    <script>
        function togglePw(id, btn) {
            const input = document.getElementById(id);
            if (input.type === 'password') { input.type = 'text'; btn.textContent = '🙈'; }
            else { input.type = 'password'; btn.textContent = '👁️'; }
        }

        function handleSocial(provider) {
            const btn = event.currentTarget;
            btn.innerHTML = '<div class="spinner" style="border-color:rgba(0,56,255,0.3);border-top-color:var(--primary);width:16px;height:16px;"></div>';
            btn.disabled = true;
            setTimeout(() => {
                btn.disabled = false;
                btn.innerHTML = provider === 'Google'
                    ? '<svg width="18" height="18" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg> Google'
                    : '<svg width="18" height="18" viewBox="0 0 24 24" fill="#1877F2"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg> Facebook';
                showError('Social login coming soon!');
            }, 1200);
        }

        function showError(msg) {
            const err = document.getElementById('errorMsg');
            err.textContent = '⚠️ ' + msg;
            err.classList.add('show');
            setTimeout(() => err.classList.remove('show'), 4000);
        }

        function handleLogin() {
            const email = document.getElementById('loginEmail').value.trim();
            const pass = document.getElementById('loginPassword').value.trim();
            const btn = document.getElementById('submitBtn');
            const errorEl = document.getElementById('errorMsg');
            const data = {}
            data.email = email
            data.password = pass

            errorEl.classList.remove('show');

            if (!email) { showError('Please enter your email address.'); return; }
            if (!pass) { showError('Please enter your password.'); return; }

            btn.innerHTML = '<div class="spinner"></div> Signing In…';
            btn.disabled = true;

            setTimeout(async() => {

                try{
                    const res = await fetch("/customer/login", {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify(data)
                    })

                    const response = await res.json()
                btn.disabled = false;
                btn.innerHTML = 'Sign In →'
                

                if(!res.ok){
                     if(response.url) window.location.href = response.url
                    if(response.error){
                        if(response.error === 'Please enter a valid email.'){
                            showError("Please enter a valid email.")
                            return;
                        }
                        showError(response.error)
                        return;
                    }
                }

                }catch(e){
                alert(e.message)
                window.location.href = '/error'
                }
                document.getElementById('loginForm').style.display = 'none';
                document.getElementById('successPanel').classList.add('show');
                setTimeout(() => { window.location.href = '/customer'; }, 2500);
            }, 1500);
        }

        document.addEventListener('keydown', e => {
            if (e.key === 'Enter') handleLogin();
        });
    </script>
</body>
</html>
