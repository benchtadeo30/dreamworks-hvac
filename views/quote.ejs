<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Get a Quote — DreamWorks HVAC</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Barlow:wght@400;500;600;700;800&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
        :root {
            --primary: #0038FF;
            --primary-dark: #0028CC;
            --primary-light: #3D68FF;
            --secondary: #00D4FF;
            --dark: #0A0F1C;
            --dark-blue: #1A1F35;
            --gray: #64748B;
            --light-gray: #E2E8F0;
            --white: #FFFFFF;
            --success: #10B981;
            --warning: #F59E0B;
            --error: #EF4444;
        }

        body {
            font-family: 'Outfit', sans-serif;
            background: linear-gradient(135deg, #0038FF 0%, #0028CC 50%, #1A1F35 100%);
            min-height: 100vh;
            padding: 2rem;
            position: relative;
            overflow-x: hidden;
        }

        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background:
                radial-gradient(circle at 20% 50%, rgba(0,212,255,0.15) 0%, transparent 50%),
                radial-gradient(circle at 80% 80%, rgba(61,104,255,0.15) 0%, transparent 50%);
            pointer-events: none;
            z-index: 0;
        }

        /* ---- Page Nav ---- */
        .page-nav {
            max-width: 1100px;
            margin: 0 auto 2rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: relative;
            z-index: 2;
            animation: fadeInDown 0.6s ease;
        }

        .brand-logo {
            font-family: 'Barlow', sans-serif;
            font-size: 1.8rem;
            font-weight: 800;
            color: #fff;
            text-transform: uppercase;
            letter-spacing: -0.5px;
            text-decoration: none;
        }

        .brand-logo span { color: var(--secondary); }

        .nav-links-row {
            display: flex;
            gap: 0.6rem;
        }

        .nav-pill {
            padding: 0.55rem 1.3rem;
            border-radius: 50px;
            font-family: 'Outfit', sans-serif;
            font-size: 0.88rem;
            font-weight: 600;
            text-decoration: none;
            border: 1.5px solid rgba(255,255,255,0.3);
            color: rgba(255,255,255,0.85);
            background: rgba(255,255,255,0.08);
            transition: all 0.25s;
            cursor: pointer;
        }

        .nav-pill:hover {
            background: rgba(255,255,255,0.18);
            color: #fff;
            border-color: rgba(255,255,255,0.5);
        }

        .nav-pill.active {
            background: #fff;
            color: var(--primary);
            border-color: #fff;
        }

        /* ---- Logo Block ---- */
        .logo {
            text-align: center;
            margin-bottom: 2.5rem;
            animation: fadeInDown 0.8s ease;
            position: relative;
            z-index: 2;
        }

        .logo h1 {
            font-family: 'Barlow', sans-serif;
            font-size: 2.6rem;
            font-weight: 800;
            color: #fff;
            text-transform: uppercase;
            letter-spacing: -1px;
        }

        .logo span { color: var(--secondary); }

        .logo p {
            color: rgba(255,255,255,0.8);
            font-size: 1rem;
            margin-top: 0.4rem;
        }

        /* ---- Main Card ---- */
        .main-card {
            background: var(--white);
            border-radius: 28px;
            box-shadow: 0 30px 80px rgba(0,0,0,0.3);
            overflow: hidden;
            max-width: 1100px;
            margin: 0 auto;
            position: relative;
            z-index: 2;
            animation: fadeInUp 0.8s ease 0.15s backwards;
        }

        /* ---- Card Header ---- */
        .card-header {
            background: linear-gradient(135deg, #f8faff, #eef2ff);
            padding: 2.5rem 3rem 2rem;
            border-bottom: 2px solid var(--light-gray);
        }

        .card-header h2 {
            font-family: 'Barlow', sans-serif;
            font-size: 2.2rem;
            font-weight: 800;
            color: var(--dark);
            margin-bottom: 0.3rem;
        }

        .card-header p { color: var(--gray); font-size: 1rem; }

        /* ---- Progress Bar ---- */
        .progress-container { padding: 2rem 3rem 0; }

        .progress-steps {
            display: flex;
            justify-content: space-between;
            position: relative;
            margin-bottom: 1rem;
        }

        .progress-steps::before {
            content: '';
            position: absolute;
            top: 20px; left: 0; right: 0;
            height: 3px;
            background: var(--light-gray);
            z-index: 0;
        }

        .progress-line {
            position: absolute;
            top: 20px; left: 0;
            height: 3px;
            background: linear-gradient(90deg, var(--primary), var(--secondary));
            transition: width 0.4s ease;
            z-index: 1;
        }

        .step {
            display: flex;
            flex-direction: column;
            align-items: center;
            position: relative;
            z-index: 2;
        }

        .step-number {
            width: 40px; height: 40px;
            border-radius: 50%;
            background: var(--white);
            border: 3px solid var(--light-gray);
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            color: var(--gray);
            transition: all 0.3s;
            margin-bottom: 0.5rem;
        }

        .step.active .step-number {
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            color: #fff;
            border-color: var(--primary);
            transform: scale(1.1);
        }

        .step.completed .step-number {
            background: var(--success);
            border-color: var(--success);
            color: #fff;
        }

        .step.completed .step-number::before { content: '✓'; }

        .step-label { font-size: 0.88rem; color: var(--gray); font-weight: 500; }
        .step.active .step-label { color: var(--primary); font-weight: 600; }

        /* ---- Form ---- */
        .tab-content { padding: 2.5rem 3rem; }

        .form-step { display: none; }
        .form-step.active { display: block; animation: slideIn 0.4s ease; }

        .form-section { margin-bottom: 2rem; }
        .form-section h3 {
            font-size: 1.2rem;
            color: var(--dark);
            margin-bottom: 1.3rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .form-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
            gap: 1.3rem;
        }

        .form-group { margin-bottom: 1.3rem; }

        .form-group label {
            display: block;
            margin-bottom: 0.45rem;
            font-weight: 500;
            color: var(--dark);
            font-size: 0.92rem;
        }

        .required { color: var(--error); }

        .form-group input,
        .form-group select,
        .form-group textarea {
            width: 100%;
            padding: 0.85rem 1.1rem;
            border: 2px solid var(--light-gray);
            border-radius: 12px;
            font-family: 'Outfit', sans-serif;
            font-size: 0.97rem;
            transition: all 0.3s;
            background: #fff;
        }

        .form-group input:focus,
        .form-group select:focus,
        .form-group textarea:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(0,56,255,0.1);
        }

        .form-group textarea { resize: vertical; min-height: 110px; }

        /* Service Cards */
        .service-selection {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 1rem;
        }

        .service-card-option { position: relative; }

        .service-card-option input {
            position: absolute;
            opacity: 0;
        }

        .service-card-option label {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 1.4rem 1rem;
            border: 2px solid var(--light-gray);
            border-radius: 14px;
            cursor: pointer;
            transition: all 0.3s;
            text-align: center;
            background: #fff;
        }

        .service-card-option input:checked + label {
            border-color: var(--primary);
            background: linear-gradient(135deg, rgba(0,56,255,0.05), rgba(0,212,255,0.05));
            box-shadow: 0 5px 20px rgba(0,56,255,0.15);
        }

        .service-card-option label:hover { border-color: var(--primary-light); transform: translateY(-3px); }

        .service-icon { font-size: 2.3rem; margin-bottom: 0.5rem; }
        .service-name { font-weight: 700; color: var(--dark); font-size: 0.88rem; margin-bottom: 0.25rem; }
        .service-desc { font-size: 0.78rem; color: var(--gray); }

        /* Property Types */
        .property-types {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
            gap: 1rem;
        }

        .property-option { position: relative; }
        .property-option input { position: absolute; opacity: 0; }

        .property-option label {
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 1.4rem;
            border: 2px solid var(--light-gray);
            border-radius: 14px;
            cursor: pointer;
            transition: all 0.3s;
            text-align: center;
        }

        .property-option input:checked + label {
            border-color: var(--primary);
            background: linear-gradient(135deg, rgba(0,56,255,0.05), rgba(0,212,255,0.05));
        }

        .property-icon { font-size: 2.8rem; margin-bottom: 0.5rem; }

        /* Date Time */
        .datetime-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.3rem; }

        /* Nav Buttons */
        .form-navigation {
            display: flex;
            justify-content: space-between;
            margin-top: 2.5rem;
            padding-top: 1.8rem;
            border-top: 2px solid var(--light-gray);
        }

        .btn {
            padding: 0.9rem 2.2rem;
            border-radius: 50px;
            font-family: 'Outfit', sans-serif;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
            border: none;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
        }

        .btn-back { background: var(--light-gray); color: var(--dark); }
        .btn-back:hover { background: #CBD5E1; transform: translateX(-4px); }

        .btn-next, .btn-submit {
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            color: #fff;
            box-shadow: 0 5px 20px rgba(0,56,255,0.3);
        }

        .btn-next:hover, .btn-submit:hover { transform: translateY(-3px); box-shadow: 0 8px 28px rgba(0,56,255,0.4); }
        .btn:disabled { opacity: 0.5; cursor: not-allowed; }

        /* Success */
        .success-message { display: none; text-align: center; padding: 3rem; }
        .success-message.active { display: block; animation: fadeIn 0.5s ease; }

        .success-icon {
            width: 90px; height: 90px;
            background: linear-gradient(135deg, var(--success), #059669);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1.8rem;
            font-size: 2.8rem;
            color: #fff;
            animation: scaleIn 0.5s ease;
        }

        .success-message h2 { font-family: 'Barlow', sans-serif; font-size: 2.2rem; color: var(--dark); margin-bottom: 0.8rem; }
        .success-message p { color: var(--gray); font-size: 1rem; margin-bottom: 1.5rem; }

        .success-details {
            background: var(--light-gray);
            padding: 1.8rem;
            border-radius: 14px;
            margin: 1.5rem 0;
            text-align: left;
        }

        .success-details h3 { color: var(--dark); margin-bottom: 0.8rem; font-size: 1rem; }

        .detail-row {
            display: flex;
            justify-content: space-between;
            padding: 0.45rem 0;
            border-bottom: 1px solid #CBD5E1;
            font-size: 0.9rem;
        }

        .detail-row:last-child { border-bottom: none; }
        .detail-label { color: var(--gray); font-weight: 500; }
        .detail-value { color: var(--dark); font-weight: 600; }

        .success-actions { display: flex; gap: 1rem; justify-content: center; margin-top: 1.5rem; flex-wrap: wrap; }

        .btn-portal {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.9rem 2rem;
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            color: #fff;
            border-radius: 50px;
            font-family: 'Outfit', sans-serif;
            font-weight: 700;
            font-size: 0.95rem;
            text-decoration: none;
            box-shadow: 0 5px 20px rgba(0,56,255,0.3);
            transition: all 0.3s;
            border: none;
            cursor: pointer;
        }

        .btn-portal:hover { transform: translateY(-3px); box-shadow: 0 10px 30px rgba(0,56,255,0.4); }

        .btn-secondary-link {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.9rem 2rem;
            background: var(--light-gray);
            color: var(--dark);
            border-radius: 50px;
            font-family: 'Outfit', sans-serif;
            font-weight: 600;
            font-size: 0.95rem;
            text-decoration: none;
            transition: all 0.3s;
        }

        .btn-secondary-link:hover { background: #CBD5E1; }

        /* Spinner */
        .spinner {
            border: 3px solid rgba(255,255,255,0.3);
            border-top: 3px solid #fff;
            border-radius: 50%;
            width: 18px; height: 18px;
            animation: spin 0.9s linear infinite;
            display: inline-block;
        }

        /* Animations */
        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
        @keyframes fadeInUp { from { opacity: 0; transform: translateY(28px); } to { opacity: 1; transform: translateY(0); } }
        @keyframes fadeInDown { from { opacity: 0; transform: translateY(-20px); } to { opacity: 1; transform: translateY(0); } }
        @keyframes slideIn { from { opacity: 0; transform: translateX(24px); } to { opacity: 1; transform: translateX(0); } }
        @keyframes scaleIn { from { transform: scale(0); } to { transform: scale(1); } }
        @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }

        @media (max-width: 768px) {
            body { padding: 1rem; }
            .tab-content { padding: 1.8rem 1.5rem; }
            .card-header { padding: 1.8rem 1.5rem 1.5rem; }
            .progress-container { padding: 1.5rem 1.5rem 0; }
            .datetime-grid { grid-template-columns: 1fr; }
            .form-navigation { flex-direction: column-reverse; gap: 0.8rem; }
            .btn { width: 100%; justify-content: center; }
            .nav-links-row { gap: 0.4rem; }
            .nav-pill { padding: 0.5rem 0.9rem; font-size: 0.8rem; }
        }

        /* ---- EULA Modal ---- */
        .eula-backdrop {
            position: fixed;
            inset: 0;
            background: rgba(10, 15, 28, 0.75);
            backdrop-filter: blur(6px);
            z-index: 9999;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 1rem;
            animation: fadeIn 0.3s ease;
        }

        .eula-modal {
            background: #fff;
            border-radius: 24px;
            width: 100%;
            max-width: 640px;
            max-height: 90vh;
            display: flex;
            flex-direction: column;
            box-shadow: 0 40px 100px rgba(0, 0, 0, 0.4);
            animation: eulaSlideUp 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
            overflow: hidden;
        }

        @keyframes eulaSlideUp {
            from { opacity: 0; transform: translateY(40px) scale(0.96); }
            to   { opacity: 1; transform: translateY(0)   scale(1); }
        }

        .eula-header {
            background: linear-gradient(135deg, #0038FF, #0028CC 60%, #1A1F35);
            padding: 1.8rem 2rem 1.5rem;
            flex-shrink: 0;
        }

        .eula-header-top {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin-bottom: 0.5rem;
        }

        .eula-icon {
            width: 48px; height: 48px;
            background: rgba(255,255,255,0.15);
            border-radius: 14px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.5rem;
            flex-shrink: 0;
        }

        .eula-header h2 {
            font-family: 'Barlow', sans-serif;
            font-size: 1.5rem;
            font-weight: 800;
            color: #fff;
            text-transform: uppercase;
            letter-spacing: -0.3px;
            line-height: 1.1;
        }

        .eula-header h2 span { color: #00D4FF; }

        .eula-header p {
            color: rgba(255,255,255,0.72);
            font-size: 0.85rem;
            margin-top: 0.3rem;
        }

        .eula-body {
            flex: 1;
            overflow-y: auto;
            padding: 1.5rem 2rem;
            scroll-behavior: smooth;
        }

        .eula-body::-webkit-scrollbar { width: 5px; }
        .eula-body::-webkit-scrollbar-thumb { background: #CBD5E1; border-radius: 99px; }

        .eula-scroll-hint {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-size: 0.75rem;
            color: var(--gray);
            background: #f8faff;
            border: 1px solid var(--light-gray);
            border-radius: 8px;
            padding: 0.5rem 0.9rem;
            margin-bottom: 1.2rem;
        }

        .eula-content {
            font-size: 0.875rem;
            color: var(--dark);
            line-height: 1.7;
        }

        .eula-content h3 {
            font-family: 'Barlow', sans-serif;
            font-size: 0.95rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: var(--primary);
            margin: 1.4rem 0 0.5rem;
            display: flex;
            align-items: center;
            gap: 0.4rem;
        }

        .eula-content h3:first-child { margin-top: 0; }

        .eula-content p {
            color: var(--gray);
            margin-bottom: 0.75rem;
        }

        .eula-content ul {
            list-style: none;
            padding: 0;
            margin: 0 0 0.75rem;
        }

        .eula-content ul li {
            color: var(--gray);
            padding: 0.3rem 0 0.3rem 1.2rem;
            position: relative;
        }

        .eula-content ul li::before {
            content: '–';
            position: absolute;
            left: 0;
            color: var(--primary);
            font-weight: 700;
        }

        .eula-placeholder {
            background: repeating-linear-gradient(
                0deg,
                #f1f5f9,
                #f1f5f9 10px,
                #e2e8f0 10px,
                #e2e8f0 11px
            );
            border-radius: 8px;
            height: 180px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            color: var(--gray);
            font-size: 0.8rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            border: 2px dashed #CBD5E1;
            margin: 0.5rem 0 1rem;
        }

        .eula-placeholder span { font-size: 1.8rem; }

        .eula-footer {
            padding: 1.2rem 2rem 1.5rem;
            border-top: 2px solid var(--light-gray);
            flex-shrink: 0;
            background: #fafcff;
        }

        .eula-agree-row {
            display: flex;
            align-items: flex-start;
            gap: 0.85rem;
            margin-bottom: 1.1rem;
            cursor: pointer;
        }

        .eula-checkbox-wrap {
            position: relative;
            flex-shrink: 0;
            margin-top: 1px;
        }

        .eula-checkbox-wrap input[type="checkbox"] {
            position: absolute;
            opacity: 0;
            width: 0; height: 0;
        }

        .eula-checkbox-custom {
            width: 22px; height: 22px;
            border: 2px solid var(--light-gray);
            border-radius: 6px;
            background: #fff;
            display: flex; align-items: center; justify-content: center;
            transition: all 0.2s;
            cursor: pointer;
        }

        .eula-checkbox-wrap input:checked ~ .eula-checkbox-custom {
            background: var(--primary);
            border-color: var(--primary);
        }

        .eula-checkbox-custom svg {
            opacity: 0;
            transition: opacity 0.15s;
        }

        .eula-checkbox-wrap input:checked ~ .eula-checkbox-custom svg {
            opacity: 1;
        }

        .eula-agree-text {
            font-size: 0.875rem;
            color: var(--dark);
            line-height: 1.5;
        }

        .eula-agree-text strong { color: var(--primary); }

        .eula-proceed-btn {
            width: 100%;
            padding: 1rem;
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            color: #fff;
            border: none;
            border-radius: 14px;
            font-family: 'Outfit', sans-serif;
            font-size: 1rem;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.6rem;
            box-shadow: 0 5px 20px rgba(0,56,255,0.3);
            opacity: 0.45;
            pointer-events: none;
        }

        .eula-proceed-btn.enabled {
            opacity: 1;
            pointer-events: all;
        }

        .eula-proceed-btn.enabled:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 30px rgba(0,56,255,0.4);
        }

        .eula-decline-link {
            display: block;
            text-align: center;
            margin-top: 0.75rem;
            font-size: 0.78rem;
            color: var(--gray);
            cursor: pointer;
            text-decoration: underline;
            transition: color 0.2s;
        }

        .eula-decline-link:hover { color: var(--error); }

        @media (max-width: 640px) {
            .eula-modal { border-radius: 20px; }
            .eula-header { padding: 1.4rem 1.4rem 1.2rem; }
            .eula-body { padding: 1.2rem 1.4rem; }
            .eula-footer { padding: 1rem 1.4rem 1.2rem; }
        }
        .upload-box {
    position: relative; /* important */
}
/* uploadpart */
/* Button style */
.upload-action-btn {
    position: center;
    bottom: 12px;
    right: 12px;

    padding: 0.6rem 1.2rem;
    border-radius: 50px;
    border: none;

    font-size: 0.85rem;
    font-weight: 600;
    font-family: 'Outfit', sans-serif;

    background: linear-gradient(135deg, var(--primary), var(--secondary));
    color: #fff;

    box-shadow: 0 4px 15px rgba(0, 56, 255, 0.25);
    cursor: pointer;

    opacity: 0.5;
    pointer-events: none;
    transition: all 0.3s ease;
}

/* Enabled state */
.upload-action-btn.enabled {
    opacity: 1;
    pointer-events: all;
}

.upload-action-btn.enabled:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 22px rgba(0, 56, 255, 0.35);
}
/* continue */
.ctn-action-btn {
    position: absolute;
    bottom: 12px;
    right: 12px;

    padding: 0.6rem 2.2rem;
    border-radius: 50px;
    border: none;

    font-size: 0.85rem;
    font-weight: 600;
    font-family: 'Outfit', sans-serif;

    background: linear-gradient(135deg, var(--primary), var(--secondary));
    color: #fff;

    box-shadow: 0 4px 15px rgba(0, 56, 255, 0.25);
    cursor: pointer;

    opacity: 0.5;
    pointer-events: none;
    transition: all 0.3s ease;
}

/* Enabled state */
.ctn-action-btn.enabled {
    opacity: 1;
    pointer-events: all;
}

.ctn-action-btn.enabled:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 22px rgba(0, 56, 255, 0.35);
}

/* Upload Box */
.upload-box {
    border: 2px dashed var(--light-gray);
    border-radius: 16px;
    padding: 2rem;
    text-align: center;
    cursor: pointer;
    background: linear-gradient(135deg, #f8faff, #eef2ff);
    transition: all 0.3s ease;
    position: relative;
}

.upload-box:hover {
    border-color: var(--primary);
    background: linear-gradient(135deg, rgba(0,56,255,0.05), rgba(0,212,255,0.05));
    transform: translateY(-2px);
}

.upload-box.dragover {
    border-color: var(--secondary);
    background: rgba(0,212,255,0.08);
}

/* Content */
.upload-icon {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
}

.upload-text {
    font-size: 0.95rem;
    color: var(--dark);
    margin-bottom: 0.2rem;
}

.upload-subtext {
    font-size: 0.8rem;
    color: var(--gray);
}

/* File Preview */
.file-preview {
    margin-top: 1rem;
    font-size: 0.85rem;
    color: var(--primary);
    font-weight: 600;
}
    </style>
