// Enable button function
function enableButton() {
    uploadBtn.disabled = false;
    uploadBtn.classList.add("enabled");
}


uploadBox.removeEventListener("click", upload)

// Click to open file
uploadBox.addEventListener("click", upload);
// File selected
fileInput.addEventListener("change", (e) => {
    const files = Array.from(fileInput.files);

    document.querySelectorAll('.file-preview').forEach(el => el.remove());

    if (files.length) {
        files.forEach(f => {
        const filePreview = document.createElement('div')
        filePreview.className = 'file-preview'
        filePreview.id = 'filePreview'
        filePreview.textContent = "📄 " + f.name;
        uploadContent.after(filePreview)
        })
        enableButton();
    }
});

// Drag events
uploadBox.addEventListener("dragover", (e) => {
    e.preventDefault();
    uploadBox.classList.add("dragover");
});

uploadBox.addEventListener("dragleave", () => {
    uploadBox.classList.remove("dragover");
});

uploadBox.addEventListener("drop", (e) => {
    e.preventDefault();
    uploadBox.classList.remove("dragover");

    const file = e.dataTransfer.files;
    fileInput.files = e.dataTransfer.files;

    if (file) {
        filePreview.textContent = "📄 " + file.name;
        enableButton();
    }
});

        function updateProgress() {
    currentStep = parseInt(sessionStorage.getItem('currentStep')) || 1;

    document.querySelectorAll('.form-step')
        .forEach(s => s.classList.remove('active'));

    const activeStep = document.querySelector(
        `.form-step[data-step="${currentStep}"]`
    );

    if (activeStep) {
        activeStep.classList.add('active');
    }

    document.querySelectorAll('.step').forEach((s, i) => {
        s.classList.remove('active', 'completed');

        if (i + 1 < currentStep) s.classList.add('completed');
        else if (i + 1 === currentStep) s.classList.add('active');
    });

    const pct = ((currentStep - 1) / 3) * 100;
    document.getElementById('progressLine').style.width = pct + '%';

    prevBtn.style.display = currentStep === 1 ? 'none' : 'inline-flex';
    nextBtn.style.display = currentStep === 4 ? 'none' : 'inline-flex';
    submitBtn.style.display = currentStep === 4 ? 'inline-flex' : 'none';
}

        async function validateStep(step) {
            const fs = document.querySelector(`.form-step[data-step="${step}"]`);
            const serviceDetails = document.querySelector("textarea[name=serviceDetails]").value.trim()
            const fileInput = document.querySelector("input[id=fileInput]")
          formData.delete("files")
            let ok = true;
            if (step === 1) {
                let chooseServices = [];
                  fs.querySelectorAll("input[type=checkbox]").forEach(service => {
                    if(service.checked){
                        chooseServices.push(service.value)
                    }
                  })
                  formData.set("service_details", serviceDetails)
                for (const file of fileInput.files) {
                    formData.append("files", file)
                    }

                  formData.set("services", JSON.stringify(chooseServices))
                  
                  try {
                   const response = await fetch("quote/1", {
                        method: 'POST',
                        body: formData,
                    })
                    
                    if(!response.ok){
                        const res = await response.text() 
                        ok = false
                         const filePreview = document.querySelectorAll("#filePreview")
                        if(filePreview) filePreview.forEach(f => f.remove())
                        document.body.innerHTML = res;
                        console.log(res)
                        const backdrop = document.getElementById('eulaBackdrop');
                        if(backdrop) backdrop.style.display = 'none'
                        return ok;
                    }

                    const data = await response.text()
                    document.querySelectorAll(".error").forEach(err => err.remove())
                    ok = true;
                    return ok;
                  } catch (error) {
                    console.log(error)
                    alert("Cannot connect to the server!")
                  }
            }

            if (step === 2) {
                const streetAddress = document.querySelector('input[name=address]').value.trim()
                const barangay = document.querySelector('input[name=barangay]').value.trim()
                const city = document.querySelector('input[name=city]').value.trim()
                const postal = document.querySelector('input[name=postal]').value.trim()
                const propertyTypes = [...document.querySelectorAll("input[name=propertyType]")]
    
                const filterPropertyType = propertyTypes.filter(property => property.checked)
                const chosenPropertyType = filterPropertyType.length > 0 ? filterPropertyType[0].value : ""

                try {
                   const response = await fetch("quote/2", {
                        method: 'POST',
                        body: JSON.stringify({
                            streetAddress,
                            barangay,
                            city,
                            postal,
                            chosenPropertyType,
                        }),
                        headers: {
                            'Content-Type': 'application/json'
                        },
                    })

                    
                    if(!response.ok){
                        const res = await response.text() 
                        ok = false
                        document.body.innerHTML = res;
                        console.log(res)
                        const backdrop = document.getElementById('eulaBackdrop');
                        if(backdrop) backdrop.style.display = 'none'
                        return ok;
                    }

                    const data = await response.text()
                    document.querySelectorAll(".error").forEach(err => err.remove())
                    ok = true;
                    return ok;
                  } catch (error) {
                    console.log(error)
                    alert("Cannot connect to the server!")
                  }
            }

            if(step === 3){
                const preferredDate = document.querySelector('input[name=preferredDate]').value.trim()
                const preferredTime = document.querySelector('select[name=preferredTime]').value.trim()
                const urgency = document.querySelector('select[name=urgency]').value.trim()
                formData.set('preferredDate', preferredDate)
                formData.set('preferredTime', preferredTime)
                formData.set('urgency', urgency)

                try {
                   const response = await fetch("quote/3", {
                        method: 'POST',
                        body: JSON.stringify({
                            preferredDate,
                            preferredTime,
                            urgency,
                        }),
                        headers: {
                            'Content-Type': 'application/json'
                        },
                    })

                    
                    if(!response.ok){
                        const res = await response.text() 
                        ok = false
                        document.body.innerHTML = res;
                        console.log(res)
                        const backdrop = document.getElementById('eulaBackdrop');
                        if(backdrop) backdrop.style.display = 'none'
                        return ok;
                    }

                    const data = await response.text()
                    document.querySelectorAll(".error").forEach(err => err.remove())
                    ok = true;
                    return ok;
                  } catch (error) {
                    console.log(error)
                    alert("Cannot connect to the server!")
                  }
            }

            if(step === 4){
                const firstName = document.querySelector("input[name=firstName]").value.trim()
                const lastName = document.querySelector("input[name=lastName]").value.trim()
                const email = document.querySelector("input[name=email]").value.trim()
                const phone = document.querySelector("input[name=phone]").value.trim()
                const referral = document.querySelector("select[name=referral]").value.trim()

                try {
                   const response = await fetch("quote/4", {
                        method: 'POST',
                        body: JSON.stringify({
                            firstName,
                            lastName,
                            email,
                            phone,
                            referral,
                        }),
                        headers: {
                            'Content-Type': 'application/json'
                        },
                    })

                    
                    if(!response.ok){
                        const res = await response.text() 
                        ok = false
                        document.body.innerHTML = res;
                        const backdrop = document.getElementById('eulaBackdrop');
                        if(backdrop) backdrop.style.display = 'none'
                        return ok;
                    }

                    const data = await response.text()
                    document.querySelectorAll(".error").forEach(err => err.remove())
                    ok = true;
                    return ok;
                  } catch (error) {
                    console.log(error)
                    alert("Cannot connect to the server!")
                  }

            }
          
        }
        document.addEventListener('click', async (e) => {
    const nextBtn = e.target.closest('#nextBtn');
    const prevBtn = e.target.closest('#prevBtn');

    if (!nextBtn && !prevBtn) return;

    e.preventDefault();

    // prevent double clicks safely
    if (window.isSubmitting) return;
    window.isSubmitting = true;

    try {

        // 👉 NEXT BUTTON
        if (nextBtn) {
    try {
        const isValid = await validateStep(currentStep);
        if (!isValid){
            updateProgress()
            run()
            return;
        }

        currentStep = Math.min(currentStep + 1, 4);

        sessionStorage.setItem('currentStep', String(currentStep));

        updateProgress();
        window.scrollTo({ top: 0, behavior: 'smooth' });

    } finally {
        window.isSubmitting = false;
    }
}

        // 👉 PREV BUTTON
        if (prevBtn) {
            if (currentStep > 1) {
                currentStep--;
                sessionStorage.setItem('currentStep', currentStep);
                updateProgress();
                window.scrollTo({ top: 0, behavior: 'smooth' });
            }
        }

    } finally {
        // ALWAYS release lock even if error happens
        window.isSubmitting = false;
    }
});

       const handleSubmit = async (e) => {
    e.preventDefault();

    if (!(await validateStep(currentStep))) {
        run();
        return;
    }

    const fd = new FormData(quoteForm);
    const services = fd.getAll('service');
    const data = {};

    for (let [k, v] of fd.entries()) {
        if (k !== 'service') data[k] = v;
    }

    submitBtn.innerHTML = '<div class="spinner"></div> Processing...';
    submitBtn.disabled = true;

    setTimeout(() => {
        quoteForm.style.display = 'none';
        document.querySelector('.progress-container').style.display = 'none';
        successMessage.classList.add('active');

       document.getElementById('quoteSummary').innerHTML = `
                    <div class="detail-row"><span class="detail-label">Name</span><span class="detail-value">${data.firstName} ${data.lastName}</span></div>
                    <div class="detail-row"><span class="detail-label">Email</span><span class="detail-value">${data.email}</span></div>
                    <div class="detail-row"><span class="detail-label">Phone</span><span class="detail-value">${data.phone}</span></div>
                    <div class="detail-row"><span class="detail-label">Services</span><span class="detail-value">${services.join(', ').replace(/-/g, ' ')}</span></div>
                    <div class="detail-row"><span class="detail-label">Location</span><span class="detail-value">${data.address}, ${data.city}</span></div>
                    <div class="detail-row"><span class="detail-label">Date & Time</span><span class="detail-value">${data.preferredDate} · ${data.preferredTime}</span></div>
                    <div class="detail-row"><span class="detail-label">Urgency</span><span class="detail-value">${data.urgency}</span></div>
                `;

        submitBtn.innerHTML = 'Submit Request ✓';
        submitBtn.disabled = false;

        sessionStorage.setItem("currentStep", JSON.stringify(1));

        quoteForm.removeEventListener('submit', handleSubmit);

    }, 1500);
};

quoteForm.removeEventListener('submit', handleSubmit);
quoteForm.addEventListener('submit', handleSubmit);

        const today = new Date().toISOString().split('T')[0];
        document.querySelectorAll('input[type="date"]').forEach(i => i.setAttribute('min', today));

        document.querySelectorAll('input, select, textarea').forEach(i => {
            i.addEventListener('input', () => i.style.borderColor = 'var(--light-gray)');
        });


        // ── EULA Functions ──
        function toggleEulaBtn(checkbox) {
            const btn = document.getElementById('eulaProceedBtn');
            btn.classList.toggle('enabled', checkbox.checked);
        }

        function acceptEula() {
            const backdrop = document.getElementById('eulaBackdrop');
            if (!document.getElementById('eulaFadeOutStyle')) {
                const s = document.createElement('style');
                s.id = 'eulaFadeOutStyle';
                s.textContent = '@keyframes fadeOut { from{opacity:1}to{opacity:0} }';
                document.head.appendChild(s);
            }
            backdrop.style.animation = 'fadeOut 0.3s ease forwards';
            setTimeout(() => { backdrop.style.display = 'none'; }, 300);
        }

        function declineEula() {
            if (confirm('Are you sure you want to decline? You will be redirected away from this page.')) {
                window.location.href = '/';
            }
        }

        // Clicking the backdrop shakes the modal instead of closing
        document.getElementById('eulaBackdrop').addEventListener('click', function(e) {
            if (e.target !== this) return;
            const modal = this.querySelector('.eula-modal');
            if (!document.getElementById('eulaShakeStyle')) {
                const s = document.createElement('style');
                s.id = 'eulaShakeStyle';
                s.textContent = '@keyframes eulaShake{0%,100%{transform:translateX(0)}20%,60%{transform:translateX(-9px)}40%,80%{transform:translateX(9px)}}';
                document.head.appendChild(s);
            }
            modal.style.animation = 'none';
            void modal.offsetWidth; // reflow
            modal.style.animation = 'eulaShake 0.4s ease';
        });

              updateProgress();
    }
       run()
    </script>
